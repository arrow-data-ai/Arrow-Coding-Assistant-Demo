{
    // Terminal optimizations for SSH connections with lag
    "terminal.integrated.scrollback": 1000,
    "terminal.integrated.fastScrollSensitivity": 5,
    
    // Disable GPU acceleration for terminal UI rendering (does NOT affect your application's GPU usage)
    // This only controls how the terminal displays text, not GPU usage by Python/CUDA/etc.
    "terminal.integrated.gpuAcceleration": "off",
    
    // Use DOM renderer instead of canvas for better responsiveness
    "terminal.integrated.rendererType": "dom",
    
    // Reduce terminal buffer size to minimize lag
    "terminal.integrated.bufferSize": 1000,
    
    // Disable smooth scrolling which can cause input lag
    "terminal.integrated.smoothScrolling": false,
    
    // Optimize cursor blinking
    "terminal.integrated.cursorBlinking": false,
    
    // Disable cursor style animations
    "terminal.integrated.cursorStyle": "line",
    
    // Reduce right click delay
    "terminal.integrated.rightClickBehavior": "default",
    
    // SSH connection optimizations
    "remote.SSH.connectTimeout": 60,
    "remote.SSH.enableAgentForwarding": false,
    "remote.SSH.enableX11Forwarding": false,
    
    // Disable auto-save which can cause network traffic spikes
    "files.autoSave": "off",
    
    // Reduce file watcher polling
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/.venv/**": true,
        "**/__pycache__/**": true
    }
}

