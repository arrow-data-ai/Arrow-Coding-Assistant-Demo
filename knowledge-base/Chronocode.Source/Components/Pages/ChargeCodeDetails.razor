@page "/chargecode-details/{ChargeCodeId:int}"
@rendermode InteractiveServer
@using Chronocode.Data.Models
@using Chronocode.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Http
@using Microsoft.Extensions.Primitives
@using System.Security.Claims
@inject ChargeCodeService ChargeCodeService
@inject WorkAuthorizationArtifactService ArtifactService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@attribute [Authorize]

<PageTitle>Charge Code Details</PageTitle>

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2>Charge Code Details</h2>
                    @if (chargeCode != null)
                    {
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a href="/projects">Projects</a></li>
                                <li class="breadcrumb-item"><a href="/projects/@chargeCode.ProjectId">@chargeCode.Project.Name</a></li>
                                <li class="breadcrumb-item active">@chargeCode.Code</li>
                            </ol>
                        </nav>
                    }
                </div>
                <button class="btn btn-secondary" @onclick="GoBack">
                    <i class="fas fa-arrow-left"></i> Back
                </button>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (chargeCode != null)
    {
        <div class="row">
            <!-- Charge Code Information -->
            <div class="col-md-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Charge Code Information</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-3">Code:</dt>
                            <dd class="col-sm-9">@chargeCode.Code</dd>
                            
                            <dt class="col-sm-3">Name:</dt>
                            <dd class="col-sm-9">@chargeCode.Name</dd>
                            
                            <dt class="col-sm-3">Description:</dt>
                            <dd class="col-sm-9">@(chargeCode.Description ?? "No description")</dd>
                            
                            <dt class="col-sm-3">Project:</dt>
                            <dd class="col-sm-9">@chargeCode.Project.Name</dd>
                            
                            <dt class="col-sm-3">Valid From:</dt>
                            <dd class="col-sm-9">@chargeCode.ValidFromDate.ToString("MM/dd/yyyy")</dd>
                            
                            <dt class="col-sm-3">Valid To:</dt>
                            <dd class="col-sm-9">@chargeCode.ValidToDate.ToString("MM/dd/yyyy")</dd>
                            
                            <dt class="col-sm-3">Activities:</dt>
                            <dd class="col-sm-9">
                                @if (activityCount > 0)
                                {
                                    <span class="badge bg-info">@activityCount</span>
                                    <span class="text-muted ms-2">activity record(s)</span>
                                }
                                else
                                {
                                    <span class="text-muted">No activities</span>
                                    <span class="badge bg-success ms-2">
                                        <i class="fas fa-check-circle"></i> Safe to delete
                                    </span>
                                }
                            </dd>
                            
                            <dt class="col-sm-3">Last Used:</dt>
                            <dd class="col-sm-9">
                                @if (lastUsedDate.HasValue)
                                {
                                    @lastUsedDate.Value.ToString("MM/dd/yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">Never used</span>
                                }
                            </dd>
                            
                            <dt class="col-sm-3">Status:</dt>
                            <dd class="col-sm-9">
                                @if (!chargeCode.IsActive)
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                    <small class="text-muted ms-2">Manually deactivated</small>
                                }
                                else if (IsChargeCodeActive())
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else if (chargeCode.ValidToDate < DateTime.Today)
                                {
                                    <span class="badge bg-danger">Expired</span>
                                    <small class="text-muted ms-2">Valid period ended</small>
                                }
                                else if (chargeCode.ValidFromDate > DateTime.Today)
                                {
                                    <span class="badge bg-warning">Not Yet Valid</span>
                                    <small class="text-muted ms-2">Valid period hasn't started</small>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Inactive</span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>

            <!-- Work Authorization Artifacts -->
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">Work Authorization Artifacts</h5>
                        <button class="btn btn-primary btn-sm" @onclick="ShowUploadModal">
                            <i class="fas fa-upload"></i> Upload
                        </button>
                    </div>
                    <div class="card-body">
                        @if (artifacts.Any())
                        {
                            <!-- Search and Filter for Artifacts -->
                            <SearchFilterBar SearchPlaceholder="Search artifacts by filename or description..."
                                             ShowInactiveFilter="true"
                                             ShowCompletedFilter="false"
                                             OnFiltersChanged="HandleArtifactFiltersChanged" />
                        }
                        
                        @if (!GetFilteredArtifacts().Any())
                        {
                            <p class="text-muted">No work authorization artifacts @(artifacts.Any() ? "match the filters" : "uploaded").</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>File Name</th>
                                            <th>Size</th>
                                            <th>Uploaded</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var artifact in GetFilteredArtifacts())
                                        {
                                            <tr>
                                                <td>
                                                    <div>
                                                        <i class="@GetFileIcon(artifact.ContentType)"></i>
                                                        @artifact.OriginalFileName
                                                    </div>
                                                    @if (!string.IsNullOrEmpty(artifact.Description))
                                                    {
                                                        <small class="text-muted">@artifact.Description</small>
                                                    }
                                                </td>
                                                <td>@FormatFileSize(artifact.FileSizeBytes)</td>
                                                <td>
                                                    <div>@artifact.UploadedDate.ToString("MM/dd/yyyy")</div>
                                                    <small class="text-muted">by @artifact.UploadedByUser.FullName</small>
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm">
                                                        <button class="btn btn-outline-primary" @onclick="() => DownloadArtifact(artifact.Id)" title="Download">
                                                            <i class="fas fa-download"></i>
                                                        </button>
                                                        <button class="btn btn-outline-danger" @onclick="() => ShowDeleteArtifactModal(artifact.Id)" title="Delete">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                        @if (CanViewInline(artifact.ContentType))
                                                        {
                                                            <button class="btn btn-outline-secondary" @onclick="() => ToggleInlineViewer(artifact.Id)" title="@(GetViewerToggleTitle(artifact.Id))">
                                                                <i class="fas @(IsViewerVisible(artifact.Id) ? "fa-eye-slash" : "fa-eye")"></i>
                                                            </button>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>

                                            @if (IsViewerVisible(artifact.Id))
                                            {
                                                <tr>
                                                    <td colspan="4">
                                                        <div class="mt-3 p-3 border rounded bg-light">
                                                            @if (artifact.ContentType == "application/pdf")
                                                            {
                                                                <object data="@ArtifactService.GetInlineViewUrl(artifact.Id)" type="application/pdf" width="100%" height="500px">
                                                                    <p>Your browser does not support inline PDF viewing. <a href="@ArtifactService.GetInlineViewUrl(artifact.Id)">Download PDF</a></p>
                                                                </object>
                                                            }
                                                            else if (IsImageType(artifact.ContentType))
                                                            {
                                                                <div class="text-center">
                                                                    <img src="@ArtifactService.GetInlineViewUrl(artifact.Id)" 
                                                                         alt="@artifact.OriginalFileName" 
                                                                         class="img-fluid" 
                                                                         style="max-height: 600px; border: 1px solid #dee2e6; border-radius: 4px;" />
                                                                </div>
                                                            }
                                                            else if (artifact.ContentType == "text/plain")
                                                            {
                                                                <div class="border rounded p-3" style="background-color: #f8f9fa; max-height: 500px; overflow-y: auto;">
                                                                    @if (textFileContents.ContainsKey(artifact.Id))
                                                                    {
                                                                        <pre style="margin: 0; white-space: pre-wrap; word-wrap: break-word; font-family: 'Courier New', monospace; font-size: 0.9em;">@textFileContents[artifact.Id]</pre>
                                                                    }
                                                                    else
                                                                    {
                                                                        <div class="text-center py-3">
                                                                            <div class="spinner-border spinner-border-sm me-2" role="status">
                                                                                <span class="visually-hidden">Loading...</span>
                                                                            </div>
                                                                            Loading text file...
                                                                        </div>
                                                                    }
                                                                </div>
                                                            }
                                                            else if (IsEmailType(artifact.ContentType))
                                                            {
                                                                <EmailViewer ArtifactId="@artifact.Id" />
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <h4>Charge Code Not Found</h4>
            <p>The requested charge code could not be found or you do not have permission to view it.</p>
        </div>
    }
</div>

<!-- Upload Modal -->
@if (showUploadModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Upload Work Authorization Artifact</h5>
                    <button type="button" class="btn-close" @onclick="HideUploadModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="uploadModel" OnValidSubmit="HandleUpload">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger" />

                        <div class="mb-3">
                            <label for="fileInput" class="form-label">Select File</label>
                            <InputFile id="fileInput" class="form-control" OnChange="OnFileSelected" accept=".pdf,.doc,.docx,.xls,.xlsx,.txt,.jpg,.jpeg,.png,.gif,.msg" />
                            <div class="form-text">
                                Allowed file types: PDF, Word, Excel, Text, Images, Email files (.msg)<br>
                                Maximum file size: 10MB
                            </div>
                            <ValidationMessage For="() => uploadModel.File" />
                        </div>

                        <div class="mb-3">
                            <label for="description" class="form-label">Description (optional)</label>
                            <InputTextArea id="description" class="form-control" @bind-Value="uploadModel.Description" rows="3" />
                            <ValidationMessage For="() => uploadModel.Description" />
                        </div>

                        @if (!string.IsNullOrEmpty(uploadMessage))
                        {
                            <div class="alert @(uploadSuccess ? "alert-success" : "alert-danger")">
                                @uploadMessage
                            </div>
                        }

                        <div class="d-flex justify-content-end">
                            <button type="button" class="btn btn-secondary me-2" @onclick="HideUploadModal">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@(isUploading || uploadModel.File == null)">
                                @if (isUploading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Upload
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Artifact Confirmation Modal -->
<ConfirmationModal IsVisible="showDeleteArtifactModal"
                  Title="Confirm Delete Artifact"
                  Message="@($"Are you sure you want to delete the artifact '{artifactToDelete?.OriginalFileName}'?")"
                  WarningMessage="This action will permanently remove the file from the system. This cannot be undone."
                  IsProcessing="isDeletingArtifact"
                  OnConfirm="ConfirmDeleteArtifact"
                  OnCancel="CancelDeleteArtifact" />

@code {
    [Parameter] public int ChargeCodeId { get; set; }

    private ChargeCode? chargeCode;
    private List<WorkAuthorizationArtifact> artifacts = new();
    private bool isLoading = true;
    private bool isUploading = false;
    private string uploadMessage = string.Empty;
    private bool uploadSuccess = false;
    
    // Activity tracking
    private int activityCount = 0;
    private DateTime? lastUsedDate = null;

    private readonly UploadModel uploadModel = new();
    private bool showUploadModal = false;
    private readonly Dictionary<int, bool> inlineViewerVisibility = new();
    private readonly Dictionary<int, string> textFileContents = new();
    
    // Delete confirmation modal state
    private bool showDeleteArtifactModal = false;
    private WorkAuthorizationArtifact? artifactToDelete = null;
    private bool isDeletingArtifact = false;

    // Search and filter state
    private string artifactSearchQuery = string.Empty;
    private bool artifactShowInactive = false;

    private void ShowUploadModal()
    {
        showUploadModal = true;
    }

    private void HideUploadModal()
    {
        showUploadModal = false;
    }

    public class UploadModel
    {
        public IBrowserFile? File { get; set; }
        public string Description { get; set; } = string.Empty;
    }

    // Wrapper class to convert IBrowserFile to IFormFile
    public class FormFileWrapper : IFormFile
    {
        private readonly byte[] _fileData;
        
        public FormFileWrapper(byte[] fileData, string fileName, string contentType)
        {
            _fileData = fileData;
            FileName = fileName;
            ContentType = contentType;
            Length = fileData.Length;
        }

        public string ContentType { get; }
        public string ContentDisposition => $"form-data; name=\"file\"; filename=\"{FileName}\"";
        public IHeaderDictionary Headers => new HeaderDictionary();
        public long Length { get; }
        public string Name => "file";
        public string FileName { get; }

        public void CopyTo(Stream target) => target.Write(_fileData, 0, _fileData.Length);
        public Task CopyToAsync(Stream target, CancellationToken cancellationToken = default) => 
            target.WriteAsync(_fileData, 0, _fileData.Length, cancellationToken);
        public Stream OpenReadStream() => new MemoryStream(_fileData);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            chargeCode = await ChargeCodeService.GetChargeCodeByIdAsync(ChargeCodeId);
            if (chargeCode != null)
            {
                artifacts = await ArtifactService.GetArtifactsByChargeCodeAsync(ChargeCodeId);
                activityCount = await ChargeCodeService.GetChargeCodeActivityCountAsync(ChargeCodeId);
                lastUsedDate = await ChargeCodeService.GetChargeCodeLastUsedDateAsync(ChargeCodeId);
            }
        }
        catch (Exception)
        {
            // Log error
        }
        finally
        {
            isLoading = false;
        }
    }

    private bool IsChargeCodeActive()
    {
        if (chargeCode == null) return false;
        var today = DateTime.Today;
        return chargeCode.IsActive && chargeCode.ValidFromDate <= today && chargeCode.ValidToDate >= today;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        uploadModel.File = e.File;
        uploadMessage = string.Empty;
    }

    private async Task HandleUpload()
    {
        if (uploadModel.File == null)
        {
            uploadMessage = "Please select a file to upload.";
            uploadSuccess = false;
            return;
        }

        isUploading = true;
        uploadMessage = string.Empty;

        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);
            if (user?.Id == null)
            {
                uploadMessage = "User not authenticated.";
                uploadSuccess = false;
                return;
            }

            // Convert IBrowserFile to IFormFile
            using var content = uploadModel.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await content.CopyToAsync(ms);

            var tempFile = new FormFileWrapper(
                ms.ToArray(),
                uploadModel.File.Name,
                uploadModel.File.ContentType);

            // Call the service to upload the file
            var result = await ArtifactService.UploadArtifactAsync(
                ChargeCodeId,
                tempFile,
                uploadModel.Description,
                user.Id);

            uploadMessage = result.Message;
            uploadSuccess = result.Success;

            if (result.Success)
            {
                await LoadData(); // Refresh the artifacts list
                showUploadModal = false;
            }
        }
        catch (Exception ex)
        {
            uploadMessage = "An error occurred while uploading the file. Please try again.";
            uploadSuccess = false;
            Console.WriteLine($"Upload error: {ex}");
        }
        finally
        {
            isUploading = false;
        }
    }

    private async Task DownloadArtifact(int artifactId)
    {
        try
        {
            Navigation.NavigateTo($"/api/artifact/download/{artifactId}", forceLoad: true);
        }
        catch (Exception ex)
        {
            uploadMessage = "An error occurred while downloading the file. Please try again.";
            Console.WriteLine($"Download error: {ex}");
        }
    }

    private void ShowDeleteArtifactModal(int artifactId)
    {
        artifactToDelete = artifacts.FirstOrDefault(a => a.Id == artifactId);
        if (artifactToDelete != null)
        {
            showDeleteArtifactModal = true;
        }
    }

    private void CancelDeleteArtifact()
    {
        showDeleteArtifactModal = false;
        artifactToDelete = null;
        isDeletingArtifact = false;
    }

    private async Task ConfirmDeleteArtifact()
    {
        if (artifactToDelete == null) return;

        try
        {
            isDeletingArtifact = true;
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);
            if (user?.Id != null)
            {
                var result = await ArtifactService.DeleteArtifactAsync(artifactToDelete.Id, user.Id);
                if (result.Success)
                {
                    await LoadData(); // Refresh the artifacts list
                    uploadMessage = "Artifact deleted successfully.";
                    uploadSuccess = true;
                    
                    // Close modal after successful deletion
                    CancelDeleteArtifact();
                }
                else
                {
                    uploadMessage = "Failed to delete the artifact.";
                    uploadSuccess = false;
                    isDeletingArtifact = false;
                }
            }
        }
        catch (Exception)
        {
            uploadMessage = "An error occurred while deleting the file.";
            uploadSuccess = false;
            isDeletingArtifact = false;
        }
    }

    private string GetFileIcon(string contentType)
    {
        return contentType.ToLowerInvariant() switch
        {
            "application/pdf" => "fas fa-file-pdf text-danger",
            "application/msword" or "application/vnd.openxmlformats-officedocument.wordprocessingml.document" => "fas fa-file-word text-primary",
            "application/vnd.ms-excel" or "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" => "fas fa-file-excel text-success",
            "text/plain" => "fas fa-file-alt text-secondary",
            "image/jpeg" or "image/png" or "image/gif" => "fas fa-file-image text-info",
            "application/vnd.ms-outlook" or "message/rfc822" => "fas fa-envelope text-warning",
            _ => "fas fa-file text-muted"
        };
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private void GoBack()
    {
        // Parse query parameters to check if we came from project detail
        var uri = new Uri(Navigation.Uri);
        var queryParams = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var returnProjectId = queryParams["returnProjectId"];
        
        if (!string.IsNullOrEmpty(returnProjectId))
        {
            // Return to project with charge codes tab active
            Navigation.NavigateTo($"/projects/{returnProjectId}?tab=chargecodes");
        }
        else
        {
            // Fallback to project detail (charge codes tab by default for this path)
            Navigation.NavigateTo($"/projects/{chargeCode?.ProjectId}?tab=chargecodes");
        }
    }

    private async Task ToggleInlineViewer(int artifactId)
    {
        if (inlineViewerVisibility.ContainsKey(artifactId))
        {
            inlineViewerVisibility[artifactId] = !inlineViewerVisibility[artifactId];
        }
        else
        {
            inlineViewerVisibility[artifactId] = true;
        }

        // Load text file content if needed
        var artifact = artifacts.FirstOrDefault(a => a.Id == artifactId);
        if (artifact != null && 
            artifact.ContentType == "text/plain" && 
            inlineViewerVisibility[artifactId] && 
            !textFileContents.ContainsKey(artifactId))
        {
            await LoadTextFileContent(artifactId);
        }
    }

    private async Task LoadTextFileContent(int artifactId)
    {
        try
        {
            var (fileStream, _, _) = await ArtifactService.GetArtifactFileAsync(artifactId);
            if (fileStream != null)
            {
                using var reader = new StreamReader(fileStream);
                var content = await reader.ReadToEndAsync();
                textFileContents[artifactId] = content;
                StateHasChanged();
            }
        }
        catch (Exception)
        {
            textFileContents[artifactId] = "Error loading file content.";
            StateHasChanged();
        }
    }

    private bool IsViewerVisible(int artifactId)
    {
        return inlineViewerVisibility.ContainsKey(artifactId) && inlineViewerVisibility[artifactId];
    }

    private string GetViewerToggleTitle(int artifactId)
    {
        return IsViewerVisible(artifactId) ? "Hide Preview" : "Show Preview";
    }

    private bool CanViewInline(string contentType)
    {
        return ArtifactService.CanViewInline(contentType);
    }

    private bool IsImageType(string contentType)
    {
        var imageTypes = new[] { "image/jpeg", "image/png", "image/gif" };
        return imageTypes.Contains(contentType.ToLowerInvariant());
    }

    private bool IsEmailType(string contentType)
    {
        var emailTypes = new[] { "application/vnd.ms-outlook", "message/rfc822" };
        return emailTypes.Contains(contentType.ToLowerInvariant());
    }

    // Filter handlers
    private void HandleArtifactFiltersChanged(SearchFilterBar.FilterState filterState)
    {
        artifactSearchQuery = filterState.SearchQuery;
        artifactShowInactive = filterState.ShowInactive;
    }

    private List<WorkAuthorizationArtifact> GetFilteredArtifacts()
    {
        var filtered = artifacts.AsEnumerable();

        // Apply search filter
        if (!string.IsNullOrWhiteSpace(artifactSearchQuery))
        {
            filtered = filtered.Where(a =>
                a.OriginalFileName.Contains(artifactSearchQuery, StringComparison.OrdinalIgnoreCase) ||
                (a.Description != null && a.Description.Contains(artifactSearchQuery, StringComparison.OrdinalIgnoreCase)));
        }

        // Apply inactive filter - by default hide inactive
        filtered = filtered.Where(a => artifactShowInactive || a.IsActive);

        return filtered.ToList();
    }
}
