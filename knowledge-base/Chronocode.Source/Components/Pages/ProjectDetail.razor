    private async Task ConfirmDeleteTask()
    {
        if (taskToDelete == null || currentUserId == null) return;

        try
        {
            isDeletingTask = true;
            await TaskService.DeleteTaskAsync(taskToDelete.Id, currentUserId);
            await LoadProject();
            
            // Close modal after successful deletion
            CancelDeleteTask();
        }
        catch (Exception ex)
        {
