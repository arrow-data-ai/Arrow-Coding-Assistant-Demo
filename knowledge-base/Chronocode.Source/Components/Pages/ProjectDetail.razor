    private bool IsChargeCodeExpired(ChargeCode chargeCode)
    {
        return chargeCode.ValidToDate < DateTime.Today;
    }

    private bool IsChargeCodeExpiringSoon(ChargeCode chargeCode)
    {
        return !IsChargeCodeExpired(chargeCode) && chargeCode.ValidToDate <= DateTime.Today.AddDays(30);
    }

    // Filter handlers
    private void HandleTaskFiltersChanged(SearchFilterBar.FilterState filterState)
    {
        taskSearchQuery = filterState.SearchQuery;
        taskShowInactive = filterState.ShowInactive;
        taskShowCompleted = filterState.ShowCompleted;
    }

    private List<ProjectTask> GetFilteredTasks()
    {
        var filtered = tasks.AsEnumerable();

        // Apply search filter
        if (!string.IsNullOrWhiteSpace(taskSearchQuery))
        {
            filtered = filtered.Where(t =>
                t.Name.Contains(taskSearchQuery, StringComparison.OrdinalIgnoreCase) ||
                (t.Description != null && t.Description.Contains(taskSearchQuery, StringComparison.OrdinalIgnoreCase)));
        }

        // Apply inactive filter - by default hide inactive
        filtered = filtered.Where(t => taskShowInactive || t.IsActive);

        // Apply completed filter - by default hide completed
        filtered = filtered.Where(t => taskShowCompleted || !t.IsComplete);

        return filtered.ToList();
    }

    private void HandleChargeCodeFiltersChanged(SearchFilterBar.FilterState filterState)
    {
        chargeCodeSearchQuery = filterState.SearchQuery;
        chargeCodeShowInactive = filterState.ShowInactive;
    }

    private void SortChargeCodes(string column)
    {
        if (chargeCodeSortColumn == column)
        {
            chargeCodeSortAscending = !chargeCodeSortAscending;
        }
        else
        {
            chargeCodeSortColumn = column;
            chargeCodeSortAscending = true;
        }
    }

    private List<ChargeCode> GetFilteredChargeCodes()
    {
        var filtered = chargeCodes.AsEnumerable();

        // Apply search filter
        if (!string.IsNullOrWhiteSpace(chargeCodeSearchQuery))
        {
            filtered = filtered.Where(cc =>
                cc.Code.Contains(chargeCodeSearchQuery, StringComparison.OrdinalIgnoreCase) ||
                cc.Name.Contains(chargeCodeSearchQuery, StringComparison.OrdinalIgnoreCase));
        }

        // Apply inactive filter - by default hide inactive
        filtered = filtered.Where(cc => chargeCodeShowInactive || cc.IsActive);

        // Apply sorting
        filtered = chargeCodeSortColumn switch
        {
            "code" => chargeCodeSortAscending ? filtered.OrderBy(cc => cc.Code) : filtered.OrderByDescending(cc => cc.Code),
            "name" => chargeCodeSortAscending ? filtered.OrderBy(cc => cc.Name) : filtered.OrderByDescending(cc => cc.Name),
            "validfrom" => chargeCodeSortAscending ? filtered.OrderBy(cc => cc.ValidFromDate) : filtered.OrderByDescending(cc => cc.ValidFromDate),
            "validto" => chargeCodeSortAscending ? filtered.OrderBy(cc => cc.ValidToDate) : filtered.OrderByDescending(cc => cc.ValidToDate),
            "activities" => chargeCodeSortAscending 
                ? filtered.OrderBy(cc => chargeCodeActivityCounts.GetValueOrDefault(cc.Id, 0)) 
                : filtered.OrderByDescending(cc => chargeCodeActivityCounts.GetValueOrDefault(cc.Id, 0)),
            "lastused" => chargeCodeSortAscending 
                ? filtered.OrderBy(cc => chargeCodeLastUsedDates.GetValueOrDefault(cc.Id) ?? DateTime.MinValue) 
                : filtered.OrderByDescending(cc => chargeCodeLastUsedDates.GetValueOrDefault(cc.Id) ?? DateTime.MinValue),
            "status" => chargeCodeSortAscending 
                ? filtered.OrderBy(cc => cc.IsActive ? (IsChargeCodeExpired(cc) ? 2 : 1) : 3)
                : filtered.OrderByDescending(cc => cc.IsActive ? (IsChargeCodeExpired(cc) ? 2 : 1) : 3),
            _ => filtered.OrderBy(cc => cc.Code)
        };

        return filtered.ToList();
    }

