    // Task methods
    private async Task ShowCreateTaskModal()
    {
        editingTask = new ProjectTask { ProjectId = ProjectId };
        copyToOtherProjects = false;
        selectedProjectIds.Clear();
        
        // Load all active non-completed projects for the multi-project copy feature
        if (currentUserId != null)
        {
            allProjects = await ProjectService.GetUserActiveProjectsAsync(currentUserId, excludeCompleted: true);
            // Remove the current project from the list
            allProjects = allProjects.Where(p => p.Id != ProjectId).ToList();
        }
        
        showTaskModal = true;
    }

    private void EditTask(ProjectTask task)
    {
        editingTask = new ProjectTask
        {
            Id = task.Id,
            Name = task.Name,
            Description = task.Description,
            ProjectId = task.ProjectId,
            CreatedDate = task.CreatedDate,
            ModifiedDate = task.ModifiedDate,
            IsActive = task.IsActive,
            IsComplete = task.IsComplete
        };
        showTaskModal = true;
    }

    private void HideTaskModal()
    {
        showTaskModal = false;
        editingTask = new();
        copyToOtherProjects = false;
        selectedProjectIds.Clear();
    }

    private async Task SaveTask()
    {
        try
        {
            if (currentUserId != null)
            {
                if (editingTask.Id == 0)
                {
                    // If copy to other projects is enabled and projects are selected
                    // Create tasks in all projects including the current one
                    if (copyToOtherProjects && selectedProjectIds.Any())
                    {
                        // Add current project to the list of projects
                        var allProjectIdList = selectedProjectIds.ToList();
                        allProjectIdList.Add(ProjectId);
                        
                        // Create tasks in all projects
                        await TaskService.CreateTaskInMultipleProjectsAsync(editingTask, allProjectIdList, currentUserId);
                    }
                    else
                    {
                        // Create task only in the current project
                        await TaskService.CreateTaskAsync(editingTask, currentUserId);
                    }
                }
                else
                {
                    await TaskService.UpdateTaskAsync(editingTask, currentUserId);
                }
                
                await LoadProject();
                HideTaskModal();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving task: {ex.Message}");
        }
    }

    private void ToggleProjectSelection(int projectId)
    {
        if (selectedProjectIds.Contains(projectId))
        {
            selectedProjectIds.Remove(projectId);
        }
        else
        {
            selectedProjectIds.Add(projectId);
        }
    }

