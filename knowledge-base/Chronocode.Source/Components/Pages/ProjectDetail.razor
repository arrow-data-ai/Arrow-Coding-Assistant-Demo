    private void CancelDeleteChargeCode()
    {
        showDeleteChargeCodeModal = false;
        chargeCodeToDeleteActivityCount = 0;
        isDeletingChargeCode = false;
    }

    private async Task ConfirmDeleteChargeCode()
    {
        if (chargeCodeToDelete == null) return;

        try
        {
            isDeletingChargeCode = true;
            
            // Try hard delete first (only works if no activities)
            bool hardDeleted = await ChargeCodeService.HardDeleteChargeCodeAsync(chargeCodeToDelete.Id);
            
            if (!hardDeleted)
            {
                // Fall back to soft delete if there are activities
                await ChargeCodeService.DeleteChargeCodeAsync(chargeCodeToDelete.Id);
            }
            
            await LoadProject();
            
            // Close modal after successful deletion
            CancelDeleteChargeCode();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting charge code: {ex.Message}");
            isDeletingChargeCode = false;
        }
    }

    private string GetDeleteChargeCodeMessage()
    {
        if (chargeCodeToDelete == null) return string.Empty;
        
        if (chargeCodeToDeleteActivityCount == 0)
        {
            return $"Are you sure you want to permanently delete the charge code '{chargeCodeToDelete.Name}'?";
        }
        else
        {
            return $"Are you sure you want to delete the charge code '{chargeCodeToDelete.Name}'? This charge code has {chargeCodeToDeleteActivityCount} activity record(s).";
        }
    }

    private string GetDeleteChargeCodeWarning()
    {
        if (chargeCodeToDeleteActivityCount == 0)
        {
            return "This charge code has no activities and will be permanently deleted. This cannot be undone.";
        }
        else
        {
            return $"This charge code has {chargeCodeToDeleteActivityCount} activity record(s) and cannot be permanently deleted. It will be deactivated instead, preserving historical data.";
        }
    }

