@page "/projects"
@rendermode InteractiveServer
@using Chronocode.Data.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@inject ProjectService ProjectService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@inject AuthorizationService AuthorizationService
@attribute [Authorize]

<PageTitle>Projects - Chronocode</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-2">
        <h1 class="mb-0">My Projects</h1>
        <HelpComponent ContextTopic="projects" IsAdmin="@isAdmin" />
    </div>
    <button class="btn btn-primary" @onclick="ShowCreateModal">
        <i class="fas fa-plus"></i> New Project
    </button>
</div>

<!-- Search and Filter -->
<SearchFilterBar SearchPlaceholder="Search projects by name or description..."
                 ShowInactiveFilter="true"
                 ShowCompletedFilter="true"
                 OnFiltersChanged="HandleFiltersChanged" />

@if (projects == null)
{
    <div class="text-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (projects.Count == 0)
{
    <div class="alert alert-info">
        <h4>No Projects Found</h4>
        <p>You don't have any projects yet. Create your first project to get started with time tracking.</p>
        <button class="btn btn-primary" @onclick="ShowCreateModal">Create Project</button>
    </div>
}
else
{
    <div class="row">
        @foreach (var project in GetFilteredProjects())
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 @(project.IsComplete ? "border-success" : "")">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title">@project.Name</h5>
                            @if (project.IsComplete)
                            {
                                <span class="badge bg-success">
                                    <i class="fas fa-check"></i> Complete
                                </span>
                            }
                        </div>
                        <p class="card-text">@(project.Description ?? "No description")</p>
                        <div class="small text-muted mb-2">
                            <div><strong>Tasks:</strong> @project.Tasks.Count(t => t.IsActive)</div>
                            <div><strong>Charge Codes:</strong> @project.ChargeCodes.Count(cc => cc.IsActive)</div>
                            <div><strong>Engineers:</strong> @project.Engineers.Count(e => e.IsActive)</div>
                            @if (project.IsComplete)
                            {
                                <div class="text-warning"><i class="fas fa-lock"></i> Completed project - limited actions available</div>
                            }
                        </div>
                    </div>
                    <div class="card-footer">
                        <div class="btn-group w-100">
                            <button class="btn btn-outline-primary" @onclick="() => ViewProject(project.Id)">
                                <i class="fas fa-eye"></i> View
                            </button>
                            @if (project.OwnerId == currentUserId || isAdmin)
                            {
                                <button class="btn btn-sm @(project.IsComplete ? "btn-warning" : "btn-success")" 
                                        @onclick="() => ToggleProjectCompletion(project.Id)"
                                        title="@(project.IsComplete ? "Mark as Incomplete" : "Mark as Complete")">
                                    <i class="fas @(project.IsComplete ? "fa-undo" : "fa-check")"></i> 
                                    @(project.IsComplete ? "Reopen" : "Complete")
                                </button>
                            }
                        </div>
                        @if (project.OwnerId == currentUserId || isAdmin)
                        {
                            <div class="btn-group w-100 mt-2">
                                <button class="btn btn-outline-success btn-sm" @onclick="() => ShowEngineerAssignmentModal(project)"
                                        disabled="@project.IsComplete">
                                    <i class="fas fa-users"></i> Manage
                                </button>
                                @if (project.OwnerId == currentUserId)
                                {
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => EditProject(project)"
                                            disabled="@project.IsComplete">
                                        <i class="fas fa-edit"></i> Edit
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => ConfirmDeleteProject(project)"
                                            disabled="@project.IsComplete">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                }
                            </div>
                        }
                        @if (!(project.OwnerId == currentUserId || isAdmin))
                        {
                            <div class="mt-2">
                                <small class="text-muted">View-only access</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Create/Edit Project Modal -->
@if (showModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingProject?.Id == 0 ? "Create Project" : "Edit Project")</h5>
                    <button type="button" class="btn-close" @onclick="HideModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editingProject" OnValidSubmit="SaveProject">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger" />
                        
                        <div class="mb-3">
                            <label for="projectName" class="form-label">Project Name *</label>
                            <InputText id="projectName" class="form-control" @bind-Value="editingProject!.Name" />
                            <ValidationMessage For="() => editingProject!.Name" />
                        </div>
                        
                        <div class="mb-3">
                            <label for="projectDescription" class="form-label">Description</label>
                            <InputTextArea id="projectDescription" class="form-control" rows="3" @bind-Value="editingProject!.Description" />
                            <ValidationMessage For="() => editingProject!.Description" />
                        </div>
                        
                        @if (editingProject?.Id != 0)
                        {
                            <div class="mb-3">
                                <div class="form-check">
                                    <InputCheckbox id="projectIsComplete" class="form-check-input" @bind-Value="editingProject!.IsComplete" />
                                    <label for="projectIsComplete" class="form-check-label">
                                        Mark as Complete
                                        <small class="text-muted d-block">Completed projects cannot have new tasks or activities added.</small>
                                    </label>
                                </div>
                            </div>
                        }
                        
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="HideModal">Cancel</button>
                            <button type="submit" class="btn btn-primary">
                                @(editingProject?.Id == 0 ? "Create" : "Update")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (showDeleteModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="HideDeleteModal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete the project <strong>@projectToDelete?.Name</strong>?</p>
                    <p class="text-warning">
                        <i class="fas fa-exclamation-triangle"></i> 
                        This action will hide the project and all its associated data. This cannot be undone.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideDeleteModal">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="DeleteProject" disabled="@isDeleting">
                        @if (isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm" role="status"></span>
                            <span>Deleting...</span>
                        }
                        else
                        {
                            <i class="fas fa-trash"></i>
                            <span>Delete Project</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Engineer Assignment Modal -->
@if (showEngineerModal && engineerAssignmentProject != null)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Manage Engineers - @engineerAssignmentProject.Name</h5>
                    <button type="button" class="btn-close" @onclick="HideEngineerModal"></button>
                </div>
                <div class="modal-body">
                    <!-- Current Engineers -->
                    <h6>Assigned Engineers</h6>
                    @if (engineerAssignmentProject.Engineers.Any(e => e.IsActive))
                    {
                        <div class="list-group mb-3">
                            @foreach (var engineer in engineerAssignmentProject.Engineers.Where(e => e.IsActive))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span>@engineer.User.FullName (@engineer.User.Email)</span>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveEngineer(engineer.UserId)">
                                        <i class="fas fa-times"></i> Remove
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No engineers assigned.</p>
                    }

                    <!-- Add Engineer -->
                    <hr />
                    <h6>Add Engineer</h6>
                    @if (availableEngineers != null)
                    {
                        <div class="row">
                            <div class="col-md-8">
                                <select class="form-select" @bind="selectedEngineerId">
                                    <option value="">Select an engineer...</option>
                                    @foreach (var engineer in availableEngineers.Where(e => !engineerAssignmentProject.Engineers.Any(pe => pe.UserId == e.Id && pe.IsActive)))
                                    {
                                        <option value="@engineer.Id">@engineer.FullName (@engineer.Email)</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <button class="btn btn-success" @onclick="AddEngineer" disabled="@(string.IsNullOrEmpty(selectedEngineerId))">
                                    <i class="fas fa-plus"></i> Add
                                </button>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideEngineerModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Project>? projects;
    private Project editingProject = new();
    private bool showModal = false;
    private bool showDeleteModal = false;
    private Project? projectToDelete;
    private bool isDeleting = false;
    private string? currentUserId;
    private bool isAdmin = false;

    // Engineer assignment modal
    private bool showEngineerModal = false;
    private Project? engineerAssignmentProject;
    private List<ApplicationUser>? availableEngineers;
    private string? selectedEngineerId;

    // Search and filter state
    private string searchQuery = string.Empty;
    private bool showInactive = false;
    private bool showCompleted = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(authState.User);
            if (user != null)
            {
                currentUserId = user.Id;
                isAdmin = await AuthorizationService.IsAdminAsync(user.Id);
                await LoadProjects();
            }
        }
    }

    private async Task LoadProjects()
    {
        if (currentUserId != null)
        {
            projects = await ProjectService.GetUserProjectsAsync(currentUserId);
        }
    }

    private void HandleFiltersChanged(SearchFilterBar.FilterState filterState)
    {
        searchQuery = filterState.SearchQuery;
        showInactive = filterState.ShowInactive;
        showCompleted = filterState.ShowCompleted;
    }

    private List<Project> GetFilteredProjects()
    {
        if (projects == null) return new List<Project>();

        var filtered = projects.AsEnumerable();

        // Apply search filter
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            filtered = filtered.Where(p =>
                p.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                (p.Description != null && p.Description.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)));
        }

        // Apply inactive filter - by default hide inactive, unless showInactive is true
        filtered = filtered.Where(p => showInactive || p.IsActive);

        // Apply completed filter - by default hide completed, unless showCompleted is true
        filtered = filtered.Where(p => showCompleted || !p.IsComplete);

        return filtered.ToList();
    }

    private void ShowCreateModal()
    {
        editingProject = new Project { OwnerId = currentUserId ?? "" };
        showModal = true;
    }

    private void EditProject(Project project)
    {
        editingProject = new Project
        {
            Id = project.Id,
            Name = project.Name,
            Description = project.Description,
            OwnerId = project.OwnerId,
            CreatedDate = project.CreatedDate,
            ModifiedDate = project.ModifiedDate,
            IsActive = project.IsActive,
            IsComplete = project.IsComplete
        };
        showModal = true;
    }

    private void HideModal()
    {
        showModal = false;
        editingProject = new();
    }

    private async Task SaveProject()
    {
        try
        {
            if (editingProject.Id == 0)
            {
                await ProjectService.CreateProjectAsync(editingProject);
            }
            else
            {
                await ProjectService.UpdateProjectAsync(editingProject);
            }
            
            await LoadProjects();
            HideModal();
        }
        catch (Exception ex)
        {
            // Handle error - in a real application, you'd want proper error handling
            Console.WriteLine($"Error saving project: {ex.Message}");
        }
    }

    private async Task ToggleProjectCompletion(int projectId)
    {
        if (currentUserId != null)
        {
            await ProjectService.ToggleProjectCompletionAsync(projectId, currentUserId);
            await LoadProjects();
        }
    }

    private void ViewProject(int projectId)
    {
        Navigation.NavigateTo($"/projects/{projectId}");
    }

    private void ConfirmDeleteProject(Project project)
    {
        projectToDelete = project;
        showDeleteModal = true;
    }

    private void HideDeleteModal()
    {
        showDeleteModal = false;
        projectToDelete = null;
        isDeleting = false;
    }

    private async Task DeleteProject()
    {
        if (projectToDelete == null || currentUserId == null) return;

        try
        {
            isDeleting = true;
            var success = await ProjectService.DeleteProjectAsync(projectToDelete.Id, currentUserId);
            
            if (success)
            {
                await LoadProjects();
                HideDeleteModal();
            }
            else
            {
                // Project not found or user doesn't have permission to delete
                Console.WriteLine("Failed to delete project - permission denied or project not found");
                isDeleting = false;
            }
        }
        catch (Exception ex)
        {
            // Handle error - in a real application, you'd want proper error handling
            Console.WriteLine($"Error deleting project: {ex.Message}");
            isDeleting = false;
        }
    }

    private async Task ShowEngineerAssignmentModal(Project project)
    {
        engineerAssignmentProject = project;
        availableEngineers = await ProjectService.GetAvailableEngineersAsync();
        selectedEngineerId = null;
        showEngineerModal = true;
    }

    private void HideEngineerModal()
    {
        showEngineerModal = false;
        engineerAssignmentProject = null;
        availableEngineers = null;
        selectedEngineerId = null;
    }

    private async Task AddEngineer()
    {
        if (engineerAssignmentProject == null || string.IsNullOrEmpty(selectedEngineerId) || currentUserId == null)
            return;

        try
        {
            var success = await ProjectService.AddEngineerToProjectAsync(
                engineerAssignmentProject.Id, 
                selectedEngineerId, 
                currentUserId);

            if (success)
            {
                await LoadProjects();
                // Refresh the current modal data
                engineerAssignmentProject = projects?.FirstOrDefault(p => p.Id == engineerAssignmentProject.Id);
                availableEngineers = await ProjectService.GetAvailableEngineersAsync();
                selectedEngineerId = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error adding engineer: {ex.Message}");
        }
    }

    private async Task RemoveEngineer(string engineerUserId)
    {
        if (engineerAssignmentProject == null || currentUserId == null)
            return;

        try
        {
            var success = await ProjectService.RemoveEngineerFromProjectAsync(
                engineerAssignmentProject.Id, 
                engineerUserId, 
                currentUserId);

            if (success)
            {
                await LoadProjects();
                // Refresh the current modal data
                engineerAssignmentProject = projects?.FirstOrDefault(p => p.Id == engineerAssignmentProject.Id);
                availableEngineers = await ProjectService.GetAvailableEngineersAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error removing engineer: {ex.Message}");
        }
    }
}
