@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Chronocode - Time Tracking</PageTitle>

<div class="hero-section text-center py-5 mb-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 10px;">
    <div class="mb-4">
        <img src="chronocodeLogo.png" alt="Chronocode Logo" class="hero-logo mb-3" style="height: 80px;" />
    </div>
    <h1 class="display-4 mb-4">Welcome to Chronocode</h1>
    <p class="lead mb-4">Professional time tracking with charge code support for engineers and project teams</p>
    
    <AuthorizeView>
        <Authorized>
            <div class="d-flex justify-content-center gap-3">
                <a href="/projects" class="btn btn-light btn-lg">
                    <i class="fas fa-folder"></i> My Projects
                </a>
                <a href="/activities" class="btn btn-outline-light btn-lg">
                    <i class="fas fa-clock"></i> Today's Activities
                </a>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="d-flex justify-content-center gap-3">
                <a href="/Account/Register" class="btn btn-light btn-lg">
                    <i class="fas fa-user-plus"></i> Get Started
                </a>
                <a href="/Account/Login" class="btn btn-outline-light btn-lg">
                    <i class="fas fa-sign-in-alt"></i> Sign In
                </a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="fas fa-project-diagram fa-3x text-primary mb-3"></i>
                <h5 class="card-title">Project Management</h5>
                <p class="card-text">Organize your work into projects and tasks. Assign team members and manage charge codes with validity periods.</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="fas fa-clock fa-3x text-success mb-3"></i>
                <h5 class="card-title">Time Tracking</h5>
                <p class="card-text">Log daily activities with precise time allocation. Support for single charge codes or even distribution across multiple codes.</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <i class="fas fa-chart-bar fa-3x text-info mb-3"></i>
                <h5 class="card-title">Reporting</h5>
                <p class="card-text">Generate comprehensive reports for timecard updates and management review. Activity, task, and charge code reports with flexible date ranges.</p>
            </div>
        </div>
    </div>
</div>

<AuthorizeView>
    <Authorized>
        <div class="row mt-5">
            <div class="col-12">
                <h3>Quick Actions</h3>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="card-title">Track Time</h6>
                                <p class="card-text">Log today's activities and allocate time to charge codes.</p>
                                <a href="/activities" class="btn btn-primary">Add Activity</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="card-title">Generate Report</h6>
                                <p class="card-text">Create timecard reports for management review.</p>
                                <a href="/reports" class="btn btn-secondary">View Reports</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Authorized>
</AuthorizeView>
