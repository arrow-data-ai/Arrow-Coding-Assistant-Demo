@page "/activities"
@rendermode InteractiveServer
@using Chronocode.Data.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@inject ActivityService ActivityService
@inject ProjectService ProjectService
@inject TaskService TaskService
@inject ChargeCodeService ChargeCodeService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation
@attribute [Authorize]

<PageTitle>Activities - Chronocode</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-2">
        <h1 class="mb-0">Today's Activities</h1>
        <HelpComponent ContextTopic="activities" />
    </div>
    <button class="btn btn-primary" @onclick="ShowCreateModal">
        <i class="fas fa-plus"></i> New Activity
    </button>
</div>

<!-- Date Filter -->
<div class="row mb-4">
    <div class="col-md-6">
        <div class="input-group">
            <span class="input-group-text">Date:</span>
            <input type="date" class="form-control" @bind="selectedDate" @bind:after="LoadActivities" />
        </div>
    </div>
    <div class="col-md-6">
        <div class="btn-group">
            <button class="btn btn-outline-secondary" @onclick="() => ChangeDate(-1)">Previous Day</button>
            <button class="btn btn-outline-secondary" @onclick="() => ChangeDate(0)">Today</button>
            <button class="btn btn-outline-secondary" @onclick="() => ChangeDate(1)">Next Day</button>
        </div>
    </div>
</div>

<!-- Search and Filter -->
<SearchFilterBar SearchPlaceholder="Search activities by name, description, task, or project..."
                 ShowInactiveFilter="true"
                 ShowCompletedFilter="false"
                 OnFiltersChanged="HandleFiltersChanged" />

@if (activities == null)
{
    <div class="text-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (activities.Count == 0)
{
    <div class="alert alert-info">
        <h4>No Activities Found</h4>
        <p>You don't have any activities recorded for @selectedDate.ToString("dddd, MMMM dd, yyyy"). Create your first activity to start tracking time.</p>
        <button class="btn btn-primary" @onclick="ShowCreateModal">Create Activity</button>
    </div>
}
else
{
    <!-- Summary -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Total Activities</h5>
                    <h3 class="text-primary">@GetFilteredActivities().Count</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Total Hours</h5>
                    <h3 class="text-success">@GetFilteredActivities().Sum(a => a.DurationHours).ToString("F1")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Projects</h5>
                    <h3 class="text-info">@GetFilteredActivities().Select(a => a.Task.ProjectId).Distinct().Count()</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">Charge Codes</h5>
                    <h3 class="text-warning">@GetFilteredActivities().SelectMany(a => a.ActivityChargeCodes).Select(acc => acc.ChargeCodeId).Distinct().Count()</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Activities List -->
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th class="sortable-header" @onclick="@(() => SortActivities("name"))">
                        Activity 
                        @if (sortColumn == "name")
                        {
                            <i class="fas @(sortAscending ? "fa-sort-up" : "fa-sort-down")"></i>
                        }
                        else
                        {
                            <i class="fas fa-sort text-muted"></i>
                        }
                    </th>
                    <th class="sortable-header" @onclick="@(() => SortActivities("task"))">
                        Task 
                        @if (sortColumn == "task")
                        {
                            <i class="fas @(sortAscending ? "fa-sort-up" : "fa-sort-down")"></i>
                        }
                        else
                        {
                            <i class="fas fa-sort text-muted"></i>
                        }
                    </th>
                    <th class="sortable-header" @onclick="@(() => SortActivities("project"))">
                        Project 
                        @if (sortColumn == "project")
                        {
                            <i class="fas @(sortAscending ? "fa-sort-up" : "fa-sort-down")"></i>
                        }
                        else
                        {
                            <i class="fas fa-sort text-muted"></i>
                        }
                    </th>
                    <th class="sortable-header" @onclick="@(() => SortActivities("duration"))">
                        Duration 
                        @if (sortColumn == "duration")
                        {
                            <i class="fas @(sortAscending ? "fa-sort-up" : "fa-sort-down")"></i>
                        }
                        else
                        {
                            <i class="fas fa-sort text-muted"></i>
                        }
                    </th>
                    <th>Charge Codes</th>
                    <th>Timer</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var activity in GetFilteredActivities())
                {
                    <tr>
                        <td>
                            <strong>@activity.Name</strong>
                            @if (!string.IsNullOrEmpty(activity.Description))
                            {
                                <br><small class="text-muted">@TruncateDescription(activity.Description)</small>
                            }
                        </td>
                        <td>@activity.Task.Name</td>
                        <td>@activity.Task.Project.Name</td>
                        <td>
                            <span class="badge bg-success">@activity.DurationHours.ToString("F1")h</span>
                        </td>
                        <td>
                            @foreach (var acc in activity.ActivityChargeCodes)
                            {
                                <span class="badge bg-secondary me-1">
                                    @acc.ChargeCode.Code (@acc.AllocatedHours.ToString("F1")h)
                                </span>
                            }
                        </td>
                        <td>
                            <ActivityTimerCompact ActivityId="@activity.Id" OnTimeSaved="@(async (hours) => await OnActivityTimerSaved(activity.Id, hours))" />
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-primary" @onclick="() => ShowDetailsModal(activity)" title="View full details">
                                    <i class="fas fa-info-circle"></i> Details
                                </button>
                                <button class="btn btn-outline-secondary" @onclick="() => EditActivity(activity)">
                                    <i class="fas fa-edit"></i> Edit
                                </button>
                                <button class="btn btn-outline-info" @onclick="() => DuplicateActivity(activity)" title="Create new activity with same project, task, and charge codes">
                                    <i class="fas fa-copy"></i> Duplicate
                                </button>
                                <button class="btn btn-outline-danger" @onclick="() => ShowDeleteModal(activity)">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Create/Edit Activity Modal -->
@if (showModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingActivity?.Id == 0 ? "Create Activity" : "Edit Activity")</h5>
                    <button type="button" class="btn-close" @onclick="HideModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="editingActivity" OnValidSubmit="SaveActivity">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger" />
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="activityName" class="form-label">Activity Name *</label>
                                    <InputText id="activityName" class="form-control" @bind-Value="editingActivity!.Name" />
                                    <ValidationMessage For="() => editingActivity!.Name" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="activityDuration" class="form-label">Duration (Hours) *</label>
                                    <InputNumber id="activityDuration" class="form-control" @bind-Value="editingActivity!.DurationHours" 
                                                 step="0.1" min="0.1" max="24" 
                                                 TValue="decimal" 
                                                 ParsingErrorMessage="Please enter a valid decimal number (e.g., 1.5)"
                                                 @bind-Value:format="F1" />
                                    <ValidationMessage For="() => editingActivity!.DurationHours" />
                                    <div class="form-text">Enter hours with 1 decimal place (e.g., 1.5, 2.0, 0.5). Minimum 0.1 hours (6 minutes). Use timer below or enter manually.</div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="activityDescription" class="form-label">Description</label>
                            <textarea id="activityDescription" class="form-control" rows="3" @bind="editingActivity!.Description" @oninput="OnDescriptionInput" maxlength="3000"></textarea>
                            <ValidationMessage For="() => editingActivity!.Description" />
                            <div class="form-text">@((editingActivity?.Description?.Length ?? 0)) / 3000 characters</div>
                        </div>

                        <!-- Activity Timer (only show for new activities) -->
                        @if (editingActivity?.Id == 0)
                        {
                            <ActivityTimerModal @ref="activityTimer" 
                                                OnTimeSaved="OnTimerSaved" 
                                                OnTimerStarted="OnTimerStarted"
                                                OnTimerStopped="OnTimerStopped" />
                        }

                        <!-- Duration Recovery (show when timer was started and original duration exists) -->
                        @if (editingActivity?.Id == 0 && originalDurationBeforeTimer.HasValue)
                        {
                            <div class="alert alert-info mt-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <small>
                                        <i class="fas fa-info-circle"></i> 
                                        Duration before timer: <strong>@originalDurationBeforeTimer.Value.ToString("F1") hours</strong>
                                    </small>
                                    <button type="button" class="btn btn-sm btn-outline-primary" @onclick="RestoreOriginalDuration">
                                        <i class="fas fa-undo"></i> Restore
                                    </button>
                                </div>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="projectSelect" class="form-label">Project *</label>
                                    <InputSelect id="projectSelect" class="form-control" @bind-Value="selectedProjectId" @bind-Value:after="OnProjectChangedAsync">
                                        <option value="">Select a project...</option>
                                        @if (userProjects != null)
                                        {
                                            @foreach (var project in userProjects.Where(p => !p.IsComplete))
                                            {
                                                <option value="@project.Id">@project.Name</option>
                                            }
                                        }
                                    </InputSelect>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="taskSelect" class="form-label">Task *</label>
                                    <div class="input-group">
                                        <InputSelect id="taskSelect" class="form-control" @bind-Value="editingActivity!.TaskId">
                                            <option value="">Select a task...</option>
                                            @if (projectTasks != null)
                                            {
                                                @foreach (var task in projectTasks.Where(t => !t.IsComplete))
                                                {
                                                    <option value="@task.Id">@task.Name</option>
                                                }
                                            }
                                        </InputSelect>
                                        @if (selectedProjectId > 0)
                                        {
                                            <button type="button" class="btn btn-outline-secondary" @onclick="RefreshTasks" title="Refresh task list">
                                                <i class="fas fa-sync-alt"></i>
                                            </button>
                                            <button type="button" class="btn btn-outline-primary" @onclick="ShowQuickTaskModal" title="Create new task for this project">
                                                <i class="fas fa-plus"></i> New Task
                                            </button>
                                        }
                                    </div>
                                    @if (selectedProjectId > 0 && projectTasks != null && !projectTasks.Any())
                                    {
                                        <div class="form-text text-info">
                                            <i class="fas fa-info-circle"></i> No tasks found for this project. Click "New Task" to create one.
                                        </div>
                                    }
                                    <ValidationMessage For="() => editingActivity!.TaskId" />
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="activityDate" class="form-label">Activity Date *</label>
                            <InputDate id="activityDate" class="form-control" @bind-Value="editingActivity!.ActivityDate" @bind-Value:after="OnActivityDateChanged" />
                            <ValidationMessage For="() => editingActivity!.ActivityDate" />
                        </div>

                        <!-- Charge Code Selection -->
                        @if (projectChargeCodes != null && projectChargeCodes.Any())
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center">
                                    <label class="form-label">Charge Codes</label>
                                    @if (selectedProjectId > 0)
                                    {
                                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="RefreshChargeCodes" title="Refresh charge codes">
                                            <i class="fas fa-sync-alt"></i> Refresh
                                        </button>
                                    }
                                </div>
                                <div class="row">
                                    @foreach (var chargeCode in projectChargeCodes)
                                    {
                                        var isExpiringSoon = chargeCode.ValidToDate <= DateTime.Today.AddDays(7);
                                        var isExpired = chargeCode.ValidToDate < editingActivity.ActivityDate || chargeCode.ValidFromDate > editingActivity.ActivityDate;
                                        
                                        <div class="col-md-4 mb-2">
                                            <div class="form-check @(isExpired ? "border border-danger rounded p-2 bg-light" : "")" style="@(isExpired ? "background-color: #fff5f5 !important;" : "")">
                                                <input type="checkbox" class="form-check-input" 
                                                       id="cc_@chargeCode.Id"
                                                       @onchange="@((ChangeEventArgs e) => OnChargeCodeToggle(chargeCode.Id, (bool)e.Value!))" 
                                                       checked="@selectedChargeCodeIds.Contains(chargeCode.Id)"
                                                       disabled="@isExpired" />
                                                <label class="form-check-label" for="cc_@chargeCode.Id" style="@(isExpired ? "color: #dc3545 !important;" : "")">
                                                    <strong style="@(isExpired ? "color: #dc3545 !important;" : "")">@chargeCode.Code</strong>
                                                    @if (isExpired)
                                                    {
                                                        <span class="badge bg-danger ms-1">Expired</span>
                                                    }
                                                    else if (isExpiringSoon)
                                                    {
                                                        <span class="badge bg-warning text-dark ms-1">Expires Soon</span>
                                                    }
                                                    <br>
                                                    <small style="@(isExpired ? "color: #dc3545 !important;" : "")">@chargeCode.Name</small><br>
                                                    <small style="@(isExpired ? "color: #dc3545 !important;" : "color: #6c757d;")">Valid: @chargeCode.ValidFromDate.ToString("MM/dd/yyyy") - @chargeCode.ValidToDate.ToString("MM/dd/yyyy")</small>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                                

                            </div>
                        }
                        else if (selectedProjectId > 0)
                        {
                            <div class="mb-3">
                                <label class="form-label">Charge Codes</label>
                                <div class="alert alert-warning">
                                    <h6><i class="fas fa-exclamation-triangle"></i> No Charge Codes Available</h6>
                                    <p>This project doesn't have any charge codes yet. You need to create charge codes before you can create activities.</p>
                                    <div class="btn-group">
                                        <button type="button" class="btn btn-warning btn-sm" @onclick="() => NavigateToProject(selectedProjectId)">
                                            <i class="fas fa-plus"></i> Create Charge Codes
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="RefreshChargeCodes">
                                            <i class="fas fa-sync-alt"></i> Refresh
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                        
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="HideModal">Cancel</button>
                            <button type="button" class="btn btn-primary" @onclick="HandleCreateActivity">
                                @(editingActivity?.Id == 0 ? "Create" : "Update")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<!-- Activity Details Modal -->
@if (showDetailsModal && detailsActivity != null)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Activity Details</h5>
                    <button type="button" class="btn-close" @onclick="HideDetailsModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Activity Name</h6>
                            <p><strong>@detailsActivity.Name</strong></p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Date</h6>
                            <p>@detailsActivity.ActivityDate.ToString("dddd, MMMM dd, yyyy")</p>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h6 class="text-muted">Project</h6>
                            <p>@detailsActivity.Task.Project.Name</p>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-muted">Task</h6>
                            <p>@detailsActivity.Task.Name</p>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <h6 class="text-muted">Duration</h6>
                            <p><span class="badge bg-success">@detailsActivity.DurationHours.ToString("F1") hours</span></p>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <h6 class="text-muted">Charge Codes</h6>
                            <div>
                                @foreach (var acc in detailsActivity.ActivityChargeCodes)
                                {
                                    <span class="badge bg-secondary me-1 mb-1">
                                        @acc.ChargeCode.Code - @acc.ChargeCode.Description (@acc.AllocatedHours.ToString("F2")h)
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="text-muted mb-0">Description</h6>
                                @if (!isEditingDescription)
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="EnableDescriptionEdit">
                                        <i class="fas fa-edit"></i> Edit Description
                                    </button>
                                }
                            </div>
                            @if (isEditingDescription)
                            {
                                <div>
                                    <textarea class="form-control mb-2" rows="5" @bind="editedDescription" @oninput="OnEditedDescriptionInput" maxlength="3000"></textarea>
                                    <div class="text-muted small mb-2">@(editedDescription?.Length ?? 0) / 3000 characters</div>
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-primary" @onclick="SaveDescriptionUpdate" disabled="@isSavingDescription">
                                            @if (isSavingDescription)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                            }
                                            Save
                                        </button>
                                        <button class="btn btn-sm btn-secondary" @onclick="CancelDescriptionEdit" disabled="@isSavingDescription">
                                            Cancel
                                        </button>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="border rounded p-3 bg-light">
                                    @if (!string.IsNullOrEmpty(detailsActivity.Description))
                                    {
                                        <p style="white-space: pre-wrap;">@detailsActivity.Description</p>
                                    }
                                    else
                                    {
                                        <p class="text-muted fst-italic">No description provided</p>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-12">
                            <small class="text-muted">
                                <span>Created: @detailsActivity.CreatedDate.ToLocalTime().ToString("g")</span>
                                @if (detailsActivity.ModifiedDate.HasValue)
                                {
                                    <span class="ms-3">Modified: @detailsActivity.ModifiedDate.Value.ToLocalTime().ToString("g")</span>
                                }
                            </small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="HideDetailsModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
<ConfirmationModal IsVisible="showDeleteModal"
                  Title="Confirm Delete Activity"
                  Message="@($"Are you sure you want to delete the activity '{activityToDelete?.Name}'?")"
                  WarningMessage="This action cannot be undone and will permanently remove the activity from your records."
                  IsProcessing="isDeleting"
                  OnConfirm="ConfirmDeleteActivity"
                  OnCancel="CancelDeleteActivity" />

<!-- Quick Task Creation Modal -->
@if (showQuickTaskModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1060;">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create New Task</h5>
                    <button type="button" class="btn-close" @onclick="HideQuickTaskModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="quickTask" OnValidSubmit="SaveQuickTask">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger" />
                        
                        <div class="mb-3">
                            <label for="quickTaskName" class="form-label">Task Name *</label>
                            <InputText id="quickTaskName" class="form-control" @bind-Value="quickTask.Name" />
                            <ValidationMessage For="() => quickTask.Name" />
                        </div>
                        
                        <div class="mb-3">
                            <label for="quickTaskDescription" class="form-label">Description</label>
                            <InputTextArea id="quickTaskDescription" class="form-control" rows="3" @bind-Value="quickTask.Description" />
                        </div>
                        
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="HideQuickTaskModal">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@isCreatingQuickTask">
                                @if (isCreatingQuickTask)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                }
                                Create Task
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const int DESCRIPTION_CHAR_LIMIT = 100;
    
    private List<Chronocode.Data.Models.Activity>? activities;
    private List<Project>? userProjects;
    private List<ProjectTask>? projectTasks;
    private List<ChargeCode>? projectChargeCodes;
    private Chronocode.Data.Models.Activity editingActivity = new();
    private bool showModal = false;
    private string? currentUserId;
    private DateTime selectedDate = DateTime.Today;
    private int selectedProjectId;
    private List<int> selectedChargeCodeIds = new();

    private ActivityTimerModal? activityTimer;
    private decimal? originalDurationBeforeTimer = null; // Store original duration when timer starts
    
    // Delete confirmation modal state
    private bool showDeleteModal = false;
    private Chronocode.Data.Models.Activity? activityToDelete = null;
    private bool isDeleting = false;
    
    // Details modal state
    private bool showDetailsModal = false;
    private Chronocode.Data.Models.Activity? detailsActivity = null;
    private bool isEditingDescription = false;
    private string? editedDescription = null;
    private bool isSavingDescription = false;
    
    // Quick task creation modal state
    private bool showQuickTaskModal = false;
    private ProjectTask quickTask = new();
    private bool isCreatingQuickTask = false;

    // Search and filter state
    private string searchQuery = string.Empty;
    private bool showInactive = false;

    // Sort state
    private string sortColumn = "name";
    private bool sortAscending = true;

    private void SortActivities(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
    }

    private void OnTimerSaved(decimal hours)
    {
        // Add the timer hours to the existing duration instead of replacing it
        editingActivity.DurationHours += hours;
        StateHasChanged();
    }

    private async Task AutoSaveTimerIfNeeded()
    {
        if (activityTimer == null) return;
        
        var elapsedSeconds = activityTimer.GetElapsedSeconds();
        if (elapsedSeconds > 0)
        {
            // Ensure duration is not null/negative - treat empty/null as 0
            if (editingActivity.DurationHours < 0)
            {
                editingActivity.DurationHours = 0;
            }
            
            // Convert timer seconds to hours and add to duration
            var timerHours = Math.Round(elapsedSeconds / 3600.0m, 1);
            editingActivity.DurationHours += timerHours;
            
            Console.WriteLine($"Auto-saved {timerHours} hours from timer. Total duration now: {editingActivity.DurationHours}");
            
            // Reset the timer since we've captured its value
            await activityTimer.ResetTimer();
        }
    }

    private async Task OnTimerStarted()
    {
        // Capture the current duration value when timer starts
        originalDurationBeforeTimer = editingActivity.DurationHours;
        Console.WriteLine($"Timer started - captured original duration: {originalDurationBeforeTimer}");
        await Task.CompletedTask; // Satisfy async signature
    }

    private async Task OnTimerStopped()
    {
        // Clear the captured duration when timer stops (user is done with timer session)
        originalDurationBeforeTimer = null;
        Console.WriteLine("Timer stopped - cleared captured duration");
        await Task.CompletedTask; // Satisfy async signature
    }

    private void RestoreOriginalDuration()
    {
        // Restore the duration that was there when timer started
        if (originalDurationBeforeTimer.HasValue)
        {
            editingActivity.DurationHours = originalDurationBeforeTimer.Value;
            Console.WriteLine($"Restored original duration: {originalDurationBeforeTimer.Value}");
            StateHasChanged();
        }
    }

    private async Task OnActivityTimerSaved(int activityId, decimal hours)
    {
        try
        {
            Console.WriteLine($"Timer save called for activity {activityId} with {hours} hours");
            
            // Get the existing activity
            var activity = await ActivityService.GetActivityByIdAsync(activityId);
            if (activity == null)
            {
                Console.WriteLine($"Activity {activityId} not found");
                return;
            }

            var originalDuration = activity.DurationHours;
            var newDuration = originalDuration + hours;
            
            Console.WriteLine($"Original duration: {originalDuration}, New duration: {newDuration}");
            
            // Update the activity duration
            activity.DurationHours = newDuration;
            
            // Get existing charge code allocations
            var existingAllocations = activity.ActivityChargeCodes
                .Select(acc => (acc.ChargeCodeId, acc.AllocatedHours))
                .ToList();
            
            Console.WriteLine($"Found {existingAllocations.Count} existing charge code allocations");
            
            List<(int ChargeCodeId, decimal Hours)> newAllocations;
            
            if (existingAllocations.Any())
            {
                if (originalDuration > 0)
                {
                    // Proportionally redistribute the total hours across existing charge codes
                    newAllocations = existingAllocations
                        .Select(alloc => (alloc.ChargeCodeId, Math.Round((alloc.AllocatedHours / originalDuration) * newDuration, 2)))
                        .ToList();
                }
                else
                {
                    // If original duration was 0, just distribute the new hours evenly
                    var hoursPerCode = Math.Round(hours / existingAllocations.Count, 2);
                    newAllocations = existingAllocations
                        .Select((alloc, index) => index == existingAllocations.Count - 1 
                            ? (alloc.ChargeCodeId, hours - (hoursPerCode * (existingAllocations.Count - 1))) // Last one gets remainder
                            : (alloc.ChargeCodeId, hoursPerCode))
                        .ToList();
                }
            }
            else
            {
                // If no existing allocations, we can't save timer hours
                Console.WriteLine($"Activity {activityId} has no charge codes. Cannot save timer hours.");
                return;
            }
            
            // Update the activity with new duration and redistributed charge codes
            await ActivityService.UpdateActivityAsync(activity, newAllocations, currentUserId!);
            Console.WriteLine($"Successfully updated activity {activityId}");
            
            // Reload activities to reflect changes
            await LoadActivities();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving timer hours for activity {activityId}: {ex.Message}");
        }
    }

