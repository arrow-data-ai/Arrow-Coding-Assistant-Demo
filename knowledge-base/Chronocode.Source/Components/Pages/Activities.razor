    private async Task SaveActivity()
    {
        try
        {
            // Validate required fields
            if (string.IsNullOrWhiteSpace(editingActivity?.Name))
            {
                Console.WriteLine("Activity name is required");
                return;
            }
            
            if (editingActivity?.TaskId == null || editingActivity.TaskId == 0)
            {
                Console.WriteLine("Task selection is required");
                return;
            }
            
            // Debug information
            Console.WriteLine($"SaveActivity called. TaskId: {editingActivity?.TaskId}, SelectedChargeCodeIds: {selectedChargeCodeIds.Count}");
            Console.WriteLine($"ProjectChargeCodes available: {projectChargeCodes?.Count ?? 0}");
            
            // For activities with positive duration, require charge codes
            if (editingActivity?.DurationHours > 0 && !selectedChargeCodeIds.Any())
            {
                Console.WriteLine("No charge codes selected for activity with recorded time - validation failed");
                // TODO: Add proper user notification here
                return;
            }

            // Validate duration is greater than 0 - activities must have a duration
            if (editingActivity?.DurationHours <= 0)
            {
                Console.WriteLine("Cannot save activity with duration of 0 or less");
                // The validation should already prevent this, but double-check here
                return;
            }

            // Validate that all selected charge codes are valid for the activity date
            var invalidChargeCodeIds = new List<int>();
            foreach (var chargeCodeId in selectedChargeCodeIds)
            {
                var isValid = await ChargeCodeService.IsChargeCodeValidAsync(chargeCodeId, editingActivity?.ActivityDate ?? DateTime.Today);
                if (!isValid)
                {
                    invalidChargeCodeIds.Add(chargeCodeId);
                }
            }

            if (invalidChargeCodeIds.Any())
            {
                // Remove invalid charge codes and show warning
                foreach (var invalidId in invalidChargeCodeIds)
                {
                    selectedChargeCodeIds.Remove(invalidId);
                }
                Console.WriteLine($"Removed {invalidChargeCodeIds.Count} expired charge codes from selection");
                
                // If no valid charge codes remain, abort save
                if (!selectedChargeCodeIds.Any())
                {
                    Console.WriteLine("No valid charge codes selected after removing expired ones");
                    // TODO: Add proper user notification here
                    return;
                }
            }

            // Validate duration is greater than 0
            if (editingActivity?.DurationHours <= 0)
            {
                Console.WriteLine("Cannot save activity with duration of 0 or less");
                // The validation should already prevent this, but double-check here
                return;
            }

            List<(int ChargeCodeId, decimal Hours)> chargeCodeAllocations;
            
            if (selectedChargeCodeIds.Count == 1)
            {
                chargeCodeAllocations = new List<(int, decimal)> { (selectedChargeCodeIds[0], editingActivity?.DurationHours ?? 0) };
            }
            else
            {
                // Distribute evenly across multiple charge codes
                chargeCodeAllocations = ActivityService.DistributeHoursEvenly(editingActivity?.DurationHours ?? 0, selectedChargeCodeIds);
            }

            if (editingActivity?.Id == 0)
            {
                await ActivityService.CreateActivityAsync(editingActivity, chargeCodeAllocations);
            }
            else
            {
                await ActivityService.UpdateActivityAsync(editingActivity!, chargeCodeAllocations, currentUserId!);
            }
            
            // Hide modal first to improve user experience
            HideModal();
            
            // Reload activities and force UI refresh
            await LoadActivities();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            // Handle specific errors for completed projects or tasks
            if (ex.Message.Contains("completed project"))
            {
                Console.WriteLine($"Cannot add activity to completed project: {ex.Message}");
                // TODO: Show user-friendly error message about completed project
            }
            else if (ex.Message.Contains("completed task"))
            {
                Console.WriteLine($"Cannot add activity to completed task: {ex.Message}");
                // TODO: Show user-friendly error message about completed task
            }
            else
            {
                // Handle other errors
                Console.WriteLine($"Error saving activity: {ex.Message}");
            }
        }
    }
    
