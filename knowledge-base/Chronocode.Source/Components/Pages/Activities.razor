    private async Task SaveDescriptionUpdate()
    {
        if (detailsActivity == null || currentUserId == null) return;

        try
        {
            isSavingDescription = true;

            // Update the activity's description
            detailsActivity.Description = editedDescription ?? string.Empty;
            detailsActivity.ModifiedDate = DateTime.UtcNow;

            // Get existing charge code allocations to pass to the update method
            var existingAllocations = detailsActivity.ActivityChargeCodes
                .Select(acc => (acc.ChargeCodeId, acc.AllocatedHours))
                .ToList();

            // Update the activity (we already checked for null above)
            await ActivityService.UpdateActivityAsync(detailsActivity!, existingAllocations, currentUserId!);

            // Reload activities to refresh the list
            await LoadActivities();

            // Update the detailsActivity reference to the refreshed data
            if (activities != null)
            {
                detailsActivity = activities.FirstOrDefault(a => a.Id == detailsActivity.Id);
            }

            // Exit edit mode
            isEditingDescription = false;
            editedDescription = null;

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating activity description: {ex.Message}");
            // Keep edit mode open to show error or retry
        }
        finally
        {
            isSavingDescription = false;
        }
    }

    private string TruncateDescription(string description)
    {
        if (string.IsNullOrEmpty(description))
            return string.Empty;

        if (description.Length <= DESCRIPTION_CHAR_LIMIT)
            return description;

        return description.Substring(0, DESCRIPTION_CHAR_LIMIT) + "...";
    }

