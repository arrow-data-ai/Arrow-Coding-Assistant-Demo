@page "/admin/users"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject AuthorizationService AuthorizationService
@attribute [Authorize]

<PageTitle>User Management - Chronocode</PageTitle>

@if (!isAdmin)
{
    <div class="alert alert-danger">
        <h4>Access Denied</h4>
        <p>You don't have permission to access this page.</p>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center">
            <h1>User Management</h1>
            <HelpComponent ContextTopic="user-management" IsAdmin="true" />
        </div>
    </div>

    <!-- Search and Filter -->
    <SearchFilterBar SearchPlaceholder="Search users by name, email, or role..."
                     ShowInactiveFilter="false"
                     ShowCompletedFilter="false"
                     OnFiltersChanged="HandleFiltersChanged" />

    @if (users == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in GetFilteredUsers())
                    {
                        <tr>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>
                                @if (userRoles.ContainsKey(user.Id))
                                {
                                    @foreach (var role in userRoles[user.Id])
                                    {
                                        <span class="badge bg-primary me-1">@role</span>
                                    }
                                }
                                @if (!userRoles.ContainsKey(user.Id) || !userRoles[user.Id].Any())
                                {
                                    <span class="text-muted">No roles</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => ShowRoleModal(user)">
                                    <i class="fas fa-user-cog"></i> Manage Roles
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Role Management Modal -->
    @if (showRoleModal && editingUser != null)
    {
        <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Manage Roles - @editingUser.FullName</h5>
                        <button type="button" class="btn-close" @onclick="HideRoleModal"></button>
                    </div>
                    <div class="modal-body">
                        @if (allRoles != null)
                        {
                            @foreach (var role in allRoles)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" 
                                           checked="@(editingUserRoles.Contains(role.Name!))" 
                                           @onchange="@((e) => ToggleRole(role.Name!, (bool)e.Value!))"
                                           id="role_@role.Id" />
                                    <label class="form-check-label" for="role_@role.Id">
                                        @role.Name
                                    </label>
                                </div>
                            }
                        }
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="HideRoleModal">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="SaveRoles" disabled="@isSavingRoles">
                            @if (isSavingRoles)
                            {
                                <span class="spinner-border spinner-border-sm" role="status"></span>
                                <span>Saving...</span>
                            }
                            else
                            {
                                <span>Save Changes</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    private List<ApplicationUser>? users;
    private readonly Dictionary<string, List<string>> userRoles = new();
    private List<IdentityRole>? allRoles;
    private bool isAdmin = false;
    private string? currentUserId;

    // Role modal
    private bool showRoleModal = false;
    private ApplicationUser? editingUser;
    private HashSet<string> editingUserRoles = new();
    private bool isSavingRoles = false;

    // Search and filter state
    private string searchQuery = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            var user = await UserManager.GetUserAsync(authState.User);
            if (user != null)
            {
                currentUserId = user.Id;
                isAdmin = await AuthorizationService.IsAdminAsync(user.Id);
                
                if (isAdmin)
                {
                    await LoadUsersAndRoles();
                }
            }
        }
    }

    private async Task LoadUsersAndRoles()
    {
        users = UserManager.Users.ToList();
        allRoles = RoleManager.Roles.ToList();
        userRoles.Clear();

        foreach (var user in users)
        {
            var roles = await UserManager.GetRolesAsync(user);
            userRoles[user.Id] = roles.ToList();
        }
    }

    private async Task ShowRoleModal(ApplicationUser user)
    {
        editingUser = user;
        var currentRoles = await UserManager.GetRolesAsync(user);
        editingUserRoles = new HashSet<string>(currentRoles);
        showRoleModal = true;
    }

    private void HideRoleModal()
    {
        showRoleModal = false;
        editingUser = null;
        editingUserRoles.Clear();
        isSavingRoles = false;
    }

    private void ToggleRole(string roleName, bool isChecked)
    {
        if (isChecked)
        {
            editingUserRoles.Add(roleName);
        }
        else
        {
            editingUserRoles.Remove(roleName);
        }
    }

    private async Task SaveRoles()
    {
        if (editingUser == null) return;

        try
        {
            isSavingRoles = true;
            
            var currentRoles = await UserManager.GetRolesAsync(editingUser);
            
            // Remove roles that are no longer selected
            var rolesToRemove = currentRoles.Where(r => !editingUserRoles.Contains(r)).ToList();
            if (rolesToRemove.Any())
            {
                await UserManager.RemoveFromRolesAsync(editingUser, rolesToRemove);
            }

            // Add new roles
            var rolesToAdd = editingUserRoles.Where(r => !currentRoles.Contains(r)).ToList();
            if (rolesToAdd.Any())
            {
                await UserManager.AddToRolesAsync(editingUser, rolesToAdd);
            }

            await LoadUsersAndRoles();
            HideRoleModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving roles: {ex.Message}");
            isSavingRoles = false;
        }
    }

    // Filter handlers
    private void HandleFiltersChanged(SearchFilterBar.FilterState filterState)
    {
        searchQuery = filterState.SearchQuery;
    }

    private List<ApplicationUser> GetFilteredUsers()
    {
        if (users == null) return new List<ApplicationUser>();

        var filtered = users.AsEnumerable();

        // Apply search filter
        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            filtered = filtered.Where(u =>
                u.FullName.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                (u.Email != null && u.Email.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)) ||
                (userRoles.ContainsKey(u.Id) && userRoles[u.Id].Any(r => r.Contains(searchQuery, StringComparison.OrdinalIgnoreCase))));
        }

        return filtered.ToList();
    }
}
