@* Reusable search and filter bar component *@

<div class="row mb-3 g-2">
    <div class="col-md-6">
        <div class="input-group">
            <span class="input-group-text">
                <i class="fas fa-search"></i>
            </span>
            <input type="text" 
                   class="form-control" 
                   placeholder="@SearchPlaceholder"
                   @bind="searchQuery" 
                   @bind:event="oninput"
                   @bind:after="OnSearchChanged" />
            @if (!string.IsNullOrEmpty(searchQuery))
            {
                <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch">
                    <i class="fas fa-times"></i>
                </button>
            }
        </div>
    </div>
    <div class="col-md-6">
        <div class="d-flex gap-3 align-items-center h-100">
            @if (ShowInactiveFilter)
            {
                <div class="form-check">
                    <input class="form-check-input" 
                           type="checkbox" 
                           id="showInactive-@componentId"
                           @bind="showInactive"
                           @bind:after="OnFilterChanged">
                    <label class="form-check-label" for="showInactive-@componentId">
                        Show Inactive
                    </label>
                </div>
            }
            @if (ShowCompletedFilter)
            {
                <div class="form-check">
                    <input class="form-check-input" 
                           type="checkbox" 
                           id="showCompleted-@componentId"
                           @bind="showCompleted"
                           @bind:after="OnFilterChanged">
                    <label class="form-check-label" for="showCompleted-@componentId">
                        Show Completed
                    </label>
                </div>
            }
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(searchQuery) || (ShowInactiveFilter && showInactive) || (ShowCompletedFilter && showCompleted))
{
    <div class="alert alert-info py-2 px-3 mb-3">
        <small>
            <i class="fas fa-filter"></i> 
            Filters active: 
            @if (!string.IsNullOrEmpty(searchQuery))
            {
                <span class="badge bg-primary me-1">Search: "@searchQuery"</span>
            }
            @if (ShowInactiveFilter && showInactive)
            {
                <span class="badge bg-secondary me-1">Showing Inactive</span>
            }
            @if (ShowCompletedFilter && showCompleted)
            {
                <span class="badge bg-success me-1">Showing Completed</span>
            }
            <button class="btn btn-sm btn-link py-0" @onclick="ClearAllFilters">Clear all</button>
        </small>
    </div>
}

@code {
    [Parameter]
    public string SearchPlaceholder { get; set; } = "Search...";

    [Parameter]
    public bool ShowInactiveFilter { get; set; } = true;

    [Parameter]
    public bool ShowCompletedFilter { get; set; } = false;

    [Parameter]
    public EventCallback<FilterState> OnFiltersChanged { get; set; }

    private string searchQuery = string.Empty;
    private bool showInactive = false;
    private bool showCompleted = false;
    private string componentId = Guid.NewGuid().ToString();

    private async Task OnSearchChanged()
    {
        await NotifyFiltersChanged();
    }

    private async Task OnFilterChanged()
    {
        await NotifyFiltersChanged();
    }

    private async Task ClearSearch()
    {
        searchQuery = string.Empty;
        await NotifyFiltersChanged();
    }

    private async Task ClearAllFilters()
    {
        searchQuery = string.Empty;
        showInactive = false;
        showCompleted = false;
        await NotifyFiltersChanged();
    }

    private async Task NotifyFiltersChanged()
    {
        var filterState = new FilterState
        {
            SearchQuery = searchQuery,
            ShowInactive = showInactive,
            ShowCompleted = showCompleted
        };
        await OnFiltersChanged.InvokeAsync(filterState);
    }

    public class FilterState
    {
        public string SearchQuery { get; set; } = string.Empty;
        public bool ShowInactive { get; set; }
        public bool ShowCompleted { get; set; }
    }
}
