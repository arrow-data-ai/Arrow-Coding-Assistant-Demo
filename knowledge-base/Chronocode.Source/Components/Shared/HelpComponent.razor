@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<div class="position-relative" @onclick:stopPropagation="true">
    <button class="btn btn-sm btn-outline-primary help-menu-button" type="button" @onclick="ToggleHelpMenu" title="Open Help Menu - Browse all documentation topics">
        <i class="fas fa-question-circle me-1"></i> Help Menu
    </button>
    
    @if (showHelpMenu)
    {
        <div class="card position-fixed shadow-lg help-dropdown" style="min-width: 300px; max-width: 350px; z-index: 99999; right: 10px; top: 60px;" @onclick:stopPropagation="true">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="fas fa-question-circle"></i> Help & Documentation</h6>
            </div>
            <div class="card-body p-0">
                <!-- Getting Started Section -->
                <div class="p-2 border-bottom bg-light">
                    <small class="text-muted fw-bold">GETTING STARTED</small>
                </div>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("getting-started"))">
                    <i class="fas fa-rocket text-primary me-2"></i> Getting Started Guide
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("user-roles"))">
                    <i class="fas fa-users text-info me-2"></i> User Roles & Permissions
                </button>
                
                <!-- Core Features Section -->
                <div class="p-2 border-bottom bg-light">
                    <small class="text-muted fw-bold">CORE FEATURES</small>
                </div>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("projects"))">
                    <i class="fas fa-folder text-warning me-2"></i> Project Management
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("tasks"))">
                    <i class="fas fa-tasks text-info me-2"></i> Task Management
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("activities"))">
                    <i class="fas fa-clock text-success me-2"></i> Activity Tracking
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("charge-codes"))">
                    <i class="fas fa-barcode text-primary me-2"></i> Charge Code Management
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("reports"))">
                    <i class="fas fa-chart-bar text-info me-2"></i> Reporting
                </button>
                
                <!-- Support Section -->
                <div class="p-2 border-bottom bg-light">
                    <small class="text-muted fw-bold">SUPPORT</small>
                </div>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("faq"))">
                    <i class="fas fa-question text-secondary me-2"></i> FAQ
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("best-practices"))">
                    <i class="fas fa-star text-warning me-2"></i> Best Practices
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("troubleshooting"))">
                    <i class="fas fa-tools text-danger me-2"></i> Troubleshooting
                </button>
                
                @if (IsAdmin)
                {
                    <!-- Admin Section -->
                    <div class="p-2 border-bottom bg-light">
                        <small class="text-muted fw-bold">ADMINISTRATION</small>
                    </div>
                    <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("user-management"))">
                        <i class="fas fa-user-cog text-primary me-2"></i> User Management
                    </button>
                    <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => OpenHelpPage("system-administration"))">
                        <i class="fas fa-cogs text-primary me-2"></i> System Administration
                    </button>
                }
                
                <!-- Close button -->
                <div class="p-2 border-top">
                    <button class="btn btn-sm btn-outline-secondary w-100" @onclick="CloseHelpMenu">
                        <i class="fas fa-times"></i> Close
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@if (showHelpMenu)
{
    <!-- Invisible backdrop to close menu when clicking outside -->
    <div class="position-fixed top-0 start-0 w-100 h-100" style="z-index: 99998;" @onclick="CloseHelpMenu"></div>
}

<!-- Context-sensitive help button for specific pages -->
@if (!string.IsNullOrEmpty(ContextTopic))
{
    <button class="btn btn-sm btn-outline-primary help-context-button ms-2" 
            @onclick="@(() => OpenHelpPage(ContextTopic))" 
            title="@GetContextHelpTooltip(ContextTopic)">
        <i class="fas fa-question-circle me-1"></i>
        <span class="help-button-text">@GetContextHelpText(ContextTopic)</span>
    </button>
}

<style>
    .help-dropdown {
        max-height: calc(100vh - 100px);
        overflow-y: auto;
    }
    
    .help-dropdown .btn-link:hover {
        background-color: rgba(0,123,255,0.1);
        text-decoration: none;
    }
    
    .help-menu-button {
        border-radius: 20px;
        font-size: 0.875rem;
        padding: 0.375rem 0.75rem;
        transition: all 0.2s ease-in-out;
        white-space: nowrap;
    }
    
    .help-menu-button:hover {
        transform: translateY(-1px);
        box-shadow: 0 2px 4px rgba(0,123,255,0.3);
    }
    
    .help-context-button {
        border-radius: 20px;
        font-size: 0.875rem;
        padding: 0.375rem 0.75rem;
        transition: all 0.2s ease-in-out;
        white-space: nowrap;
    }
    
    .help-context-button:hover {
        transform: translateY(-1px);
        box-shadow: 0 2px 4px rgba(0,123,255,0.3);
    }
    
    .help-button-text {
        font-weight: 500;
    }
    
    @@media (max-width: 768px) {
        .help-button-text {
            display: none;
        }
        .help-context-button {
            padding: 0.375rem 0.5rem;
        }
    }
</style>

@code {
    [Parameter] public string? ContextTopic { get; set; }
    [Parameter] public bool IsAdmin { get; set; }

    private bool showHelpMenu = false;

    private async Task ToggleHelpMenu()
    {
        await JSRuntime.InvokeVoidAsync("console.log", "Help button clicked");
        showHelpMenu = !showHelpMenu;
        StateHasChanged();
    }

    private void CloseHelpMenu()
    {
        showHelpMenu = false;
        StateHasChanged();
    }

    private async Task OpenHelpPage(string topic)
    {
        CloseHelpMenu();
        
        // Validate and encode topic to prevent injection
        if (string.IsNullOrWhiteSpace(topic))
            return;
            
        var encodedTopic = Uri.EscapeDataString(topic);
        
        // Open in a new tab - using dedicated JS function for security validation and tabnabbing prevention
        await JSRuntime.InvokeVoidAsync("openHelpPage", $"/help/{encodedTopic}");
    }

    private static string GetContextHelpText(string topic)
    {
        return topic switch
        {
            "projects" => "Project Help",
            "activities" => "Activity Help", 
            "reports" => "Report Help",
            "user-management" => "User Help",
            "tasks" => "Task Help",
            "charge-codes" => "Charge Code Help",
            _ => "Help"
        };
    }

    private static string GetContextHelpTooltip(string topic)
    {
        return topic switch
        {
            "projects" => "Open Project Management help guide",
            "activities" => "Open Activity Tracking help guide",
            "reports" => "Open Reporting help guide", 
            "user-management" => "Open User Management help guide",
            "tasks" => "Open Task Management help guide",
            "charge-codes" => "Open Charge Code Management help guide",
            _ => "Open help documentation for this page"
        };
    }
}
