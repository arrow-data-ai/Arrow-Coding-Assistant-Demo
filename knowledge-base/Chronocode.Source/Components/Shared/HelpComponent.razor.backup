    private string GetTaskManagementContent()
    {
        return @"
        <h1>Task Management</h1>
        <p>Tasks organize work within projects and are required for all time tracking activities.</p>
        
        <h2>Creating Tasks</h2>
        <ol>
            <li>Go to <strong>Project Details</strong> (click 'View' on a project)</li>
            <li>Select the <strong>Tasks</strong> tab</li>
            <li>Click <strong>New Task</strong></li>
            <li>Enter task name and description</li>
            <li>Click <strong>Create</strong></li>
        </ol>
        
        <h2>Task Organization</h2>
        <div class='row'>
            <div class='col-md-6'>
                <h6>📋 By Phase</h6>
                <ul>
                    <li>Requirements</li>
                    <li>Design</li>
                    <li>Development</li>
                    <li>Testing</li>
                    <li>Deployment</li>
                </ul>
            </div>
            <div class='col-md-6'>
                <h6>🔧 By Feature</h6>
                <ul>
                    <li>User Authentication</li>
                    <li>Payment Processing</li>
                    <li>Reporting</li>
                    <li>User Interface</li>
                    <li>API Development</li>
                </ul>
            </div>
        </div>
        
        <h2>Best Practices</h2>
        <ul>
            <li>Use clear, action-oriented task names</li>
            <li>Keep tasks focused (4-40 hours of work)</li>
            <li>Include specific deliverables in descriptions</li>
            <li>Break large tasks into smaller components</li>
        </ul>
        
        <div class='alert alert-info'>
            <h6>💡 Remember</h6>
            <p>Every activity must be associated with a task. Create tasks before team members start logging time!</p>
        </div>";
    }

    private string GetChargeCodeManagementContent()
    {
        return @"
        <h1>Charge Code Management</h1>
        <p>Charge codes are billing identifiers that specify how time should be allocated for accounting and billing purposes.</p>
        
        <h2>Creating Charge Codes</h2>
        <ol>
            <li>Go to <strong>Project Details</strong></li>
            <li>Select the <strong>Charge Codes</strong> tab</li>
            <li>Click <strong>New Charge Code</strong></li>
            <li>Fill in charge code details:
                <ul>
                    <li><strong>Code</strong>: Unique identifier (e.g., ENG-001)</li>
                    <li><strong>Name</strong>: Descriptive name</li>
                    <li><strong>Valid From/To</strong>: Date range when code is available</li>
                </ul>
            </li>
            <li>Click <strong>Create</strong></li>
        </ol>
        
        <h2>Charge Code Categories</h2>
        <div class='row'>
            <div class='col-md-6'>
                <h6>💼 Direct Client Work</h6>
                <ul>
                    <li>Development</li>
                    <li>Design</li>
                    <li>Testing</li>
                    <li>Client meetings</li>
                </ul>
            </div>
            <div class='col-md-6'>
                <h6>🏢 Internal Work</h6>
                <ul>
                    <li>Infrastructure</li>
                    <li>Training</li>
                    <li>Administration</li>
                    <li>Research</li>
                </ul>
            </div>
        </div>
        
        <h2>Using Charge Codes</h2>
        <div class='alert alert-success'>
            <h6>Time Allocation Options:</h6>
            <ul>
                <li><strong>Single Code</strong>: All time to one charge code</li>
                <li><strong>Even Split</strong>: Use 'Peanut Butter Spread' for equal distribution</li>
                <li><strong>Custom Split</strong>: Manually specify hours for each code</li>
            </ul>
        </div>
        
        <h2>Validity Periods</h2>
        <p>Charge codes have start and end dates to ensure accurate billing:</p>
        <ul>
            <li>Only valid codes appear in activity creation</li>
            <li>Codes must be valid for the activity date</li>
            <li>Contact project owner to extend validity periods</li>
        </ul>
        
        <div class='alert alert-warning'>
            <h6>⚠️ Important</h6>
            <p>Follow your organization's charge code guidelines for consistent billing and reporting.</p>
        </div>";
    }
}
