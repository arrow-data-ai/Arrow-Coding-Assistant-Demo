@using Microsoft.JSInterop
@using Chronocode.Services
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@inject HelpService HelpService

<div class="position-relative" @onclick:stopPropagation="true">
    <button class="btn btn-outline-secondary" type="button" @onclick="ToggleHelpMenu" title="Help & Documentation">
        <i class="fas fa-question-circle"></i> Help
    </button>
    
    @if (showHelpMenu)
    {
        <div @ref="helpDropdownRef" class="card position-fixed shadow-lg help-dropdown" style="min-width: 300px; max-width: 350px; z-index: 99999; right: 10px; top: 60px;" @onclick:stopPropagation="true">
            <div class="card-header bg-primary text-white">
                <h6 class="mb-0"><i class="fas fa-question-circle"></i> Help & Documentation</h6>
            </div>
            <div class="card-body p-0">
                <!-- Getting Started Section -->
                <div class="p-2 border-bottom bg-light">
                    <small class="text-muted fw-bold">GETTING STARTED</small>
                </div>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => ShowHelpModal("getting-started"))">
                    <i class="fas fa-rocket text-primary me-2"></i> Getting Started Guide
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => ShowHelpModal("user-roles"))">
                    <i class="fas fa-users text-info me-2"></i> User Roles & Permissions
                </button>
                
                <!-- Core Features Section -->
                <div class="p-2 border-bottom bg-light">
                    <small class="text-muted fw-bold">CORE FEATURES</small>
                </div>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => ShowHelpModal("projects"))">
                    <i class="fas fa-folder text-warning me-2"></i> Project Management
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => ShowHelpModal("tasks"))">
                    <i class="fas fa-tasks text-info me-2"></i> Task Management
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => ShowHelpModal("activities"))">
                    <i class="fas fa-clock text-success me-2"></i> Activity Tracking
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => ShowHelpModal("charge-codes"))">
                    <i class="fas fa-barcode text-primary me-2"></i> Charge Code Management
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => ShowHelpModal("reports"))">
                    <i class="fas fa-chart-bar text-info me-2"></i> Reporting
                </button>
                
                <!-- Support Section -->
                <div class="p-2 border-bottom bg-light">
                    <small class="text-muted fw-bold">SUPPORT</small>
                </div>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => ShowHelpModal("faq"))">
                    <i class="fas fa-question text-secondary me-2"></i> FAQ
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => ShowHelpModal("best-practices"))">
                    <i class="fas fa-star text-warning me-2"></i> Best Practices
                </button>
                <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => ShowHelpModal("troubleshooting"))">
                    <i class="fas fa-tools text-danger me-2"></i> Troubleshooting
                </button>
                
                @if (isAdmin)
                {
                    <!-- Admin Section -->
                    <div class="p-2 border-bottom bg-light">
                        <small class="text-muted fw-bold">ADMINISTRATION</small>
                    </div>
                    <button class="btn btn-link text-start w-100 border-0 p-2" @onclick="@(() => ShowHelpModal("user-management"))">
                        <i class="fas fa-user-cog text-primary me-2"></i> User Management
                    </button>
                }
                
                <!-- Close button -->
                <div class="p-2 border-top">
                    <button class="btn btn-sm btn-outline-secondary w-100" @onclick="CloseHelpMenu">
                        <i class="fas fa-times"></i> Close
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@if (showHelpMenu)
{
    <!-- Invisible backdrop to close menu when clicking outside -->
    <div class="position-fixed top-0 start-0 w-100 h-100" style="z-index: 99998;" @onclick="CloseHelpMenu"></div>
}

<!-- Help Modal - Bootstrap Version for Testing -->
@if (showHelpModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 999999 !important;">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="fas fa-question-circle text-primary"></i> @(string.IsNullOrEmpty(helpTitle) ? "Loading..." : helpTitle)
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseHelp" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (isLoading)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Loading help content...</p>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(helpContent))
                    {
                        @((MarkupString)helpContent)
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <h6>Help Content Not Available</h6>
                            <p>The requested help content could not be loaded. Please contact your system administrator for assistance.</p>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseHelp">Close</button>
                    <button type="button" class="btn btn-primary" @onclick="@(() => ShowHelpModal("README"))">
                        <i class="fas fa-home"></i> Help Home
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Context-sensitive help button for specific pages -->
@if (!string.IsNullOrEmpty(contextTopic))
{
    <button class="btn btn-sm btn-outline-info ms-2" @onclick="@(() => ShowHelpModal(contextTopic))" title="Page-specific help">
        <i class="fas fa-question"></i>
    </button>
}

<style>
    .help-content {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
    }
    
    .help-content h1 {
        color: #0366d6;
        border-bottom: 1px solid #e1e4e8;
        padding-bottom: 0.3em;
        margin-bottom: 1em;
    }
    
    .help-content h2 {
        color: #24292e;
        border-bottom: 1px solid #e1e4e8;
        padding-bottom: 0.3em;
        margin-top: 2em;
        margin-bottom: 1em;
    }
    
    .help-content h3 {
        color: #24292e;
        margin-top: 1.5em;
        margin-bottom: 0.5em;
    }
    
    .help-content code {
        background-color: rgba(27,31,35,0.05);
        border-radius: 3px;
        font-size: 85%;
        margin: 0;
        padding: 0.2em 0.4em;
    }
    
    .help-content pre {
        background-color: #f6f8fa;
        border-radius: 6px;
        font-size: 85%;
        line-height: 1.45;
        overflow: auto;
        padding: 16px;
    }
    
    .help-content blockquote {
        border-left: 0.25em solid #dfe2e5;
        color: #6a737d;
        margin: 0;
        padding: 0 1em;
    }
    
    .help-content table {
        border-collapse: collapse;
        margin: 1em 0;
        width: 100%;
    }
    
    .help-content table th,
    .help-content table td {
        border: 1px solid #dfe2e5;
        padding: 8px 12px;
        text-align: left;
    }
    
    .help-content table th {
        background-color: #f6f8fa;
        font-weight: 600;
    }
    
    .help-menu-item:hover {
        background-color: #f8f9fa !important;
        text-decoration: none;
    }
    
    /* Help Dropdown Styling */
    .help-dropdown {
        animation: slideIn 0.2s ease-out;
        z-index: 9999 !important;
        border: 1px solid #ddd;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    }
    
    .position-relative {
        position: relative !important;
    }
    
    /* Custom Help Modal - Fixes z-index issues */
    .help-modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(0, 0, 0, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 999999 !important;
        overflow-y: auto;
        padding: 1rem;
        box-sizing: border-box;
    }
    
    .help-modal-container {
        width: 100%;
        max-width: 90vw;
        max-height: 90vh;
        margin: auto;
        z-index: 999999 !important;
    }
    
    .help-modal-content {
        background: white;
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        max-height: 90vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        z-index: 999999 !important;
    }
    
    .help-modal-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #e9ecef;
        background-color: #f8f9fa;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-shrink: 0;
    }
    
    .help-modal-title {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 600;
        color: #495057;
    }
    
    .help-modal-close {
        background: none;
        border: none;
        font-size: 1.25rem;
        color: #6c757d;
        cursor: pointer;
        padding: 0.25rem;
        border-radius: 4px;
        transition: color 0.15s ease-in-out, background-color 0.15s ease-in-out;
    }
    
    .help-modal-close:hover {
        color: #495057;
        background-color: #e9ecef;
    }
    
    .help-modal-body {
        padding: 1.5rem;
        overflow-y: auto;
        flex: 1;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
    }
    
    .help-modal-footer {
        padding: 1rem 1.5rem;
        border-top: 1px solid #e9ecef;
        background-color: #f8f9fa;
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
        flex-shrink: 0;
    }
    
    /* Apply help content styles to modal body */
    .help-modal-body h1 {
        color: #0366d6;
        border-bottom: 1px solid #e1e4e8;
        padding-bottom: 0.3em;
        margin-bottom: 1em;
        margin-top: 0;
    }
    
    .help-modal-body h2 {
        color: #24292e;
        border-bottom: 1px solid #e1e4e8;
        padding-bottom: 0.3em;
        margin-top: 2em;
        margin-bottom: 1em;
    }
    
    .help-modal-body h3 {
        color: #24292e;
        margin-top: 1.5em;
        margin-bottom: 0.5em;
    }
    
    .help-modal-body code {
        background-color: rgba(27,31,35,0.05);
        border-radius: 3px;
        font-size: 85%;
        margin: 0;
        padding: 0.2em 0.4em;
    }
    
    .help-modal-body pre {
        background-color: #f6f8fa;
        border-radius: 6px;
        font-size: 85%;
        line-height: 1.45;
        overflow: auto;
        padding: 16px;
    }
    
    .help-modal-body blockquote {
        border-left: 0.25em solid #dfe2e5;
        color: #6a737d;
        margin: 0;
        padding: 0 1em;
    }
    
    .help-modal-body table {
        border-collapse: collapse;
        margin: 1em 0;
        width: 100%;
    }
    
    .help-modal-body table th,
    .help-modal-body table td {
        border: 1px solid #dfe2e5;
        padding: 8px 12px;
        text-align: left;
    }
    
    .help-modal-body table th {
        background-color: #f6f8fa;
        font-weight: 600;
    }
    
    /* Responsive Design */
    @@media (max-width: 768px) {
        .help-modal-container {
            max-width: 95vw;
            margin: 0.5rem;
        }
        
        .help-modal-content {
            max-height: 95vh;
        }
        
        .help-modal-header,
        .help-modal-body,
        .help-modal-footer {
            padding: 1rem;
        }
        
        .help-modal-footer {
            flex-direction: column;
        }
        
        .help-modal-footer .btn {
            width: 100%;
        }
    }
    
    /* Animation */
    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    /* Ensure help system is always on top of everything else */
    .help-modal-backdrop,
    .help-modal-container,
    .help-modal-content {
        z-index: 999999 !important;
    }
    
    /* Override any Bootstrap or other modal z-indexes */
    body.help-modal-open {
        overflow: hidden;
    }
    
    /* Force the help modal above Bootstrap modals */
    .help-modal-backdrop {
        z-index: 999999 !important;
    }
</style>

<script>
    window.positionHelpDropdown = (dropdownElement) => {
        if (!dropdownElement) return;
        
        const viewportWidth = window.innerWidth;
        const dropdownWidth = 350; // max width
        
        // Position from right edge with padding, but ensure it doesn't go off left edge
        if (viewportWidth < dropdownWidth + 20) {
            // On very small screens, center it with small margins
            dropdownElement.style.right = '10px';
            dropdownElement.style.left = '10px';
            dropdownElement.style.maxWidth = (viewportWidth - 20) + 'px';
        } else {
            // Normal positioning from right edge
            dropdownElement.style.right = '10px';
            dropdownElement.style.left = 'auto';
            dropdownElement.style.maxWidth = '350px';
        }
        
        // Ensure it's positioned near the top
        dropdownElement.style.top = '60px';
    };
</script>

@code {
    [Parameter] public string? ContextTopic { get; set; }
    [Parameter] public bool IsAdmin { get; set; }

    private bool showHelpModal = false;
    private bool showHelpMenu = false;
    private bool isLoading = false;
    private string helpContent = string.Empty;
    private string helpTitle = string.Empty;
    private string contextTopic = string.Empty;
    private bool isAdmin = false;
    private ElementReference helpDropdownRef;

    protected override void OnInitialized()
    {
        base.OnInitialized();
    }

    protected override void OnParametersSet()
    {
        contextTopic = ContextTopic ?? string.Empty;
        isAdmin = IsAdmin;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
    }

    private async Task ToggleHelpMenu()
    {
        showHelpMenu = !showHelpMenu;
        if (showHelpMenu)
        {
            StateHasChanged();
            await Task.Delay(10); // Allow DOM to update
            await PositionDropdown();
        }
        else
        {
            StateHasChanged();
        }
    }

    private void CloseHelpMenu()
    {
        showHelpMenu = false;
        StateHasChanged();
    }

    private async Task PositionDropdown()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("positionHelpDropdown", helpDropdownRef);
        }
        catch (Exception)
        {
            // Fallback to CSS positioning if JS fails
        }
    }

    private async Task ShowHelpModal(string topic)
    {
        try
        {
            showHelpMenu = false; // Close the menu
            showHelpModal = true;
            isLoading = true;
            helpContent = string.Empty;
            
            // Force a state change to ensure the modal renders
            StateHasChanged();
            
            var (content, title) = await HelpService.GetHelpContentAsync(topic);
            helpContent = content;
            helpTitle = title;
        }
        catch (Exception ex)
        {
            helpContent = $"<div class='alert alert-danger'><h6>Error Loading Help</h6><p>Could not load help content: {ex.Message}</p></div>";
            helpTitle = "Help Error";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void CloseHelp()
    {
        showHelpModal = false;
        helpContent = string.Empty;
        helpTitle = string.Empty;
        StateHasChanged();
    }

    private async Task<(string content, string title)> LoadHelpContent(string topic)
    {
        var fileName = topic switch
        {
            "getting-started" => "Getting-Started.md",
            "user-roles" => "User-Roles-and-Permissions.md",
            "projects" => "Project-Management.md",
            "tasks" => "Task-Management.md",
            "activities" => "Activity-Tracking.md",
            "charge-codes" => "Charge-Code-Management.md",
            "reports" => "Reporting.md",
            "user-management" => "User-Management.md",
            "faq" => "FAQ.md",
            "best-practices" => "Best-Practices.md",
            "troubleshooting" => "Troubleshooting.md",
            _ => "README.md"
        };

        var title = topic switch
        {
            "getting-started" => "Getting Started Guide",
            "user-roles" => "User Roles & Permissions",
            "projects" => "Project Management",
            "tasks" => "Task Management",
            "activities" => "Activity Tracking",
            "charge-codes" => "Charge Code Management",
            "reports" => "Reporting",
            "user-management" => "User Management (Admin)",
            "faq" => "Frequently Asked Questions",
            "best-practices" => "Best Practices",
            "troubleshooting" => "Troubleshooting",
            _ => "Chronocode Help"
        };

        try
        {
            // In a real implementation, you would load the markdown file and convert to HTML
            // For now, we'll return a placeholder that indicates the system is working
            var content = await LoadMarkdownContent(fileName);
            return (ConvertMarkdownToHtml(content), title);
        }
        catch
        {
            // Fallback content if file loading fails
            var fallbackContent = GenerateFallbackContent(topic, title);
            return (fallbackContent, title);
        }
    }

    private async Task<string> LoadMarkdownContent(string fileName)
    {
        // This is a simplified version - in a real implementation, you would:
        // 1. Read the markdown file from the file system or embedded resources
        // 2. Use a markdown parser to convert to HTML
        // For now, we'll return formatted content based on the topic

        await Task.Delay(500); // Simulate loading time

        return fileName switch
        {
            "Getting-Started.md" => GetGettingStartedContent(),
            "FAQ.md" => GetFAQContent(),
            "Project-Management.md" => GetProjectManagementContent(),
            "Task-Management.md" => GetTaskManagementContent(),
            "Activity-Tracking.md" => GetActivityTrackingContent(),
            "Charge-Code-Management.md" => GetChargeCodeManagementContent(),
            "Reporting.md" => GetReportingContent(),
            "User-Management.md" => GetUserManagementContent(),
            _ => GetDefaultHelpContent()
        };
    }

    private string ConvertMarkdownToHtml(string markdown)
    {
        // In a real implementation, you would use a markdown parser like Markdig
        // For now, we'll return the content as-is since we're providing HTML directly
        return markdown;
    }

    private string GenerateFallbackContent(string topic, string title)
    {
        return $@"
        <div class='alert alert-info'>
            <h4><i class='fas fa-info-circle'></i> {title}</h4>
            <p>Welcome to the help system for <strong>{title}</strong>.</p>
            <p>This feature is designed to provide comprehensive guidance for using Chronocode effectively.</p>
            <hr>
            <p><strong>For immediate assistance:</strong></p>
            <ul>
                <li>Contact your system administrator</li>
                <li>Refer to your organization's time tracking policies</li>
                <li>Check with your project manager for project-specific guidance</li>
            </ul>
        </div>";
    }

    private string GetGettingStartedContent()
    {
        return @"
        <h1>Getting Started with Chronocode</h1>
        <p>Welcome to Chronocode! This guide will help you get up and running quickly.</p>
        
        <h2>First Steps</h2>
        <ol>
            <li><strong>Account Setup</strong> - Ensure your account is properly configured</li>
            <li><strong>Role Assignment</strong> - Get appropriate roles from your administrator</li>
            <li><strong>Project Access</strong> - Be assigned to projects you'll work on</li>
            <li><strong>First Activity</strong> - Log your first time entry</li>
        </ol>
        
        <h2>Basic Workflow</h2>
        <div class='alert alert-success'>
            <h6>Daily Time Tracking Process:</h6>
            <ol>
                <li>Go to <strong>Activities</strong> page</li>
                <li>Click <strong>New Activity</strong></li>
                <li>Fill in activity details (name, project, task, duration)</li>
                <li>Select appropriate charge codes</li>
                <li>Save and repeat throughout the day</li>
            </ol>
        </div>
        
        <h2>Key Concepts</h2>
        <ul>
            <li><strong>Projects</strong> - Top-level work organization</li>
            <li><strong>Tasks</strong> - Specific work items within projects</li>
            <li><strong>Activities</strong> - Your actual time entries</li>
            <li><strong>Charge Codes</strong> - Billing categories for time allocation</li>
        </ul>
        
        <h2>Need Help?</h2>
        <p>If you need assistance:</p>
        <ul>
            <li>Check the FAQ section</li>
            <li>Contact your system administrator</li>
            <li>Ask your project manager about charge codes</li>
        </ul>";
    }

    private string GetFAQContent()
    {
        return @"
        <h1>Frequently Asked Questions</h1>
        
        <h2>Getting Started</h2>
        <div class='mb-3'>
            <h6>Q: I can't see any projects. What should I do?</h6>
            <p><strong>A:</strong> Contact your administrator to assign you to projects and give you the appropriate role (usually Engineer).</p>
        </div>
        
        <div class='mb-3'>
            <h6>Q: What are charge codes and why do I need them?</h6>
            <p><strong>A:</strong> Charge codes are billing identifiers that specify how your time should be allocated. They're essential for accurate client billing and project accounting.</p>
        </div>
        
        <h2>Time Tracking</h2>
        <div class='mb-3'>
            <h6>Q: How do I log time for work I did yesterday?</h6>
            <p><strong>A:</strong> Use the date picker on the Activities page to select yesterday's date, then create your activity.</p>
        </div>
        
        <div class='mb-3'>
            <h6>Q: Can I split my time across multiple charge codes?</h6>
            <p><strong>A:</strong> Yes! Select multiple charge codes and either use 'Peanut Butter Spread' for even distribution or manually allocate specific hours to each code.</p>
        </div>
        
        <h2>Reporting</h2>
        <div class='mb-3'>
            <h6>Q: How do I generate a timecard?</h6>
            <p><strong>A:</strong> Go to Reports, select your report type (Daily, Weekly, or Custom), choose dates, and click Generate Report.</p>
        </div>
        
        <div class='alert alert-info'>
            <h6>Need More Help?</h6>
            <p>Browse other help topics or contact your system administrator for additional assistance.</p>
        </div>";
    }

    private string GetProjectManagementContent()
    {
        return @"
        <h1>Project Management</h1>
        <p>Projects are the foundation of time tracking in Chronocode.</p>
        
        <h2>Creating Projects</h2>
        <ol>
            <li>Go to the <strong>Projects</strong> page</li>
            <li>Click <strong>New Project</strong></li>
            <li>Enter project name and description</li>
            <li>Click <strong>Create</strong></li>
        </ol>
        
        <h2>Project Components</h2>
        <div class='row'>
            <div class='col-md-6'>
                <h6>📋 Tasks</h6>
                <p>Organize work into specific tasks and deliverables.</p>
            </div>
            <div class='col-md-6'>
                <h6>💰 Charge Codes</h6>
                <p>Create billing codes for time allocation.</p>
            </div>
        </div>
        
        <h2>Team Management</h2>
        <div class='alert alert-warning'>
            <h6>Engineer Assignment</h6>
            <p>Use the <strong>Manage</strong> button on projects to assign engineers. Only admins and project owners can assign team members.</p>
        </div>
        
        <h2>Best Practices</h2>
        <ul>
            <li>Use clear, descriptive project names</li>
            <li>Break work into logical tasks</li>
            <li>Set up charge codes before time tracking begins</li>
            <li>Assign team members at project start</li>
        </ul>";
    }

    private string GetActivityTrackingContent()
    {
        return @"
        <h1>Activity Tracking</h1>
        <p>Activities represent actual work performed and are the core of time tracking.</p>
        
        <h2>Creating Activities</h2>
        <div class='alert alert-success'>
            <h6>Quick Activity Creation:</h6>
            <ol>
                <li>Click <strong>New Activity</strong> on the Activities page</li>
                <li>Enter activity name and description</li>
                <li>Select project and task</li>
                <li>Enter duration in decimal hours (e.g., 1.5 = 1hr 30min)</li>
                <li>Choose charge codes for billing</li>
                <li>Save the activity</li>
            </ol>
        </div>
        
        <h2>Charge Code Allocation</h2>
        <h6>Three Ways to Allocate Time:</h6>
        <ul>
            <li><strong>Single Code</strong> - All time to one charge code</li>
            <li><strong>Even Split</strong> - Use 'Peanut Butter Spread' for equal distribution</li>
            <li><strong>Custom Split</strong> - Manually specify hours for each code</li>
        </ul>
        
        <h2>Best Practices</h2>
        <div class='row'>
            <div class='col-md-6'>
                <h6>✅ Good Habits</h6>
                <ul>
                    <li>Log time immediately after work</li>
                    <li>Use descriptive activity names</li>
                    <li>Be accurate with duration</li>
                    <li>Review daily before leaving</li>
                </ul>
            </div>
            <div class='col-md-6'>
                <h6>❌ Avoid These</h6>
                <ul>
                    <li>Waiting until end of week</li>
                    <li>Vague activity descriptions</li>
                    <li>Guessing at time amounts</li>
                    <li>Ignoring charge code guidelines</li>
                </ul>
            </div>
        </div>";
    }

    private string GetReportingContent()
    {
        return @"
        <h1>Reporting</h1>
        <p>Generate comprehensive time reports for timecards and analysis.</p>
        
        <h2>Report Types</h2>
        <div class='row'>
            <div class='col-md-4'>
                <div class='card'>
                    <div class='card-body text-center'>
                        <h6>📅 Daily</h6>
                        <p>Single day summary</p>
                    </div>
                </div>
            </div>
            <div class='col-md-4'>
                <div class='card'>
                    <div class='card-body text-center'>
                        <h6>📊 Weekly</h6>
                        <p>Monday-Sunday compilation</p>
                    </div>
                </div>
            </div>
            <div class='col-md-4'>
                <div class='card'>
                    <div class='card-body text-center'>
                        <h6>📈 Custom Range</h6>
                        <p>Any date range</p>
                    </div>
                </div>
            </div>
        </div>
        
        <h2>Generating Reports</h2>
        <ol>
            <li>Go to the <strong>Reports</strong> page</li>
            <li>Select report type from dropdown</li>
            <li>Choose date(s) using date picker</li>
            <li>Click <strong>Generate Report</strong></li>
            <li>Review and print/export as needed</li>
        </ol>
        
        <h2>Report Content</h2>
        <ul>
            <li><strong>Summary Cards</strong> - Total hours, activities, projects</li>
            <li><strong>Charge Code Breakdown</strong> - Hours per billing code</li>
            <li><strong>Detailed Activities</strong> - Complete activity list</li>
            <li><strong>Project Analysis</strong> - Time distribution across projects</li>
        </ul>
        
        <div class='alert alert-info'>
            <h6>💡 Tip</h6>
            <p>Use your browser's print function to save reports as PDF files for permanent records.</p>
        </div>";
    }

    private string GetUserManagementContent()
    {
        return @"
        <h1>User Management (Admin Only)</h1>
        <div class='alert alert-warning'>
            <h6>🔒 Administrator Access Required</h6>
            <p>This functionality is only available to users with the Administrator role.</p>
        </div>
        
        <h2>Managing User Roles</h2>
        <ol>
            <li>Navigate to <strong>User Management</strong> in the admin section</li>
            <li>Find the user in the list</li>
            <li>Click <strong>Manage Roles</strong></li>
            <li>Check/uncheck roles as needed</li>
            <li>Click <strong>Save Changes</strong></li>
        </ol>
        
        <h2>Available Roles</h2>
        <div class='row'>
            <div class='col-md-6'>
                <h6>👑 Admin</h6>
                <p>Full system access, user management, all projects</p>
                
                <h6>🔧 Engineer</h6>
                <p>Time tracking on assigned projects</p>
            </div>
            <div class='col-md-6'>
                <h6>👔 Manager</h6>
                <p>Project oversight and team reporting</p>
                
                <h6>👤 User</h6>
                <p>Basic access to owned projects</p>
            </div>
        </div>
        
        <h2>Engineer Assignment</h2>
        <p>To assign engineers to projects:</p>
        <ol>
            <li>Go to <strong>Projects</strong> page</li>
            <li>Click <strong>Manage</strong> on the desired project</li>
            <li>Select engineers from the dropdown</li>
            <li>Click <strong>Add</strong> to assign</li>
        </ol>
        
        <h2>Best Practices</h2>
        <ul>
            <li>Follow principle of least privilege</li>
            <li>Assign roles promptly for new users</li>
            <li>Regular role audits (monthly/quarterly)</li>
            <li>Document role assignment reasoning</li>
        </ul>";
    }

