@using System.Timers
@implements IDisposable

<div class="card mt-3" style="border: 2px solid #007bff;">
    <div class="card-header bg-primary text-white">
        <h6 class="mb-0">
            <i class="fas fa-stopwatch"></i> Activity Timer
        </h6>
    </div>
    <div class="card-body">
        <div class="text-center mb-3">
            <div class="timer-display" style="font-family: 'Courier New', monospace; font-size: 2rem; font-weight: bold; color: #007bff;">
                @FormatTime(elapsedSeconds)
            </div>
        </div>
        
        <div class="d-flex justify-content-center gap-2">
            <button type="button" class="btn @(isRunning ? "btn-secondary" : "btn-success") btn-sm" 
                    @onclick="StartTimer" 
                    disabled="@isRunning">
                <i class="fas fa-play"></i> Start
            </button>
            
            <button type="button" class="btn @(isRunning ? "btn-warning" : "btn-secondary") btn-sm" 
                    @onclick="StopTimer" 
                    disabled="@(!isRunning)">
                <i class="fas fa-pause"></i> Stop
            </button>
            
            <button type="button" class="btn btn-outline-secondary btn-sm" 
                    @onclick="ResetTimer">
                <i class="fas fa-undo"></i> Reset
            </button>
            
            <button type="button" class="btn btn-primary btn-sm" 
                    @onclick="SaveTime" 
                    disabled="@(elapsedSeconds == 0)">
                <i class="fas fa-save"></i> Save Time
            </button>
        </div>
        
        @if (elapsedSeconds > 0)
        {
            <div class="mt-2 text-center">
                <small class="text-muted">
                    This will add approximately @ConvertToHours(elapsedSeconds).ToString("F1") hours to the Duration field
                </small>
            </div>
        }
        
        @if (lastSavedTime > 0)
        {
            <div class="mt-2 text-center">
                <div class="alert alert-success alert-sm py-1 px-2">
                    <small><i class="fas fa-check"></i> Added @lastSavedTime.ToString("F1") hours to Duration field</small>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback<decimal> OnTimeSaved { get; set; }
    [Parameter] public EventCallback OnTimerStarted { get; set; }
    [Parameter] public EventCallback OnTimerStopped { get; set; }
    
    private bool isRunning = false;
    private int elapsedSeconds = 0;
    private decimal lastSavedTime = 0;
    private System.Timers.Timer? timer;

    protected override void OnInitialized()
    {
        timer = new System.Timers.Timer(1000); // 1 second interval
        timer.Elapsed += OnTimerElapsed;
    }

    private async Task StartTimer()
    {
        if (!isRunning && timer != null)
        {
            isRunning = true;
            timer.Start();
            await OnTimerStarted.InvokeAsync();
        }
    }

    private async Task StopTimer()
    {
        if (isRunning && timer != null)
        {
            isRunning = false;
            timer.Stop();
            await OnTimerStopped.InvokeAsync();
        }
    }

    public async Task ResetTimer()
    {
        await StopTimer();
        elapsedSeconds = 0;
        lastSavedTime = 0;
        await InvokeAsync(StateHasChanged);
    }

    // Public methods for parent component integration
    public int GetElapsedSeconds() => elapsedSeconds;

    private async Task SaveTime()
    {
        if (elapsedSeconds > 0)
        {
            var hours = ConvertToHours(elapsedSeconds);
            lastSavedTime = hours;
            await OnTimeSaved.InvokeAsync(hours);
            
            // Reset the timer but keep the saved time indicator
            await StopTimer();
            elapsedSeconds = 0;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void OnTimerElapsed(object? sender, ElapsedEventArgs e)
    {
        elapsedSeconds++;
        await InvokeAsync(StateHasChanged);
    }

    private static string FormatTime(int totalSeconds)
    {
        var hours = totalSeconds / 3600;
        var minutes = (totalSeconds % 3600) / 60;
        var seconds = totalSeconds % 60;
        return $"{hours:D2}:{minutes:D2}:{seconds:D2}";
    }

    private static decimal ConvertToHours(int totalSeconds)
    {
        var hours = totalSeconds / 3600.0m;
        // Round to nearest tenth of an hour
        return Math.Round(hours, 1);
    }

    public void Dispose()
    {
        timer?.Stop();
        timer?.Dispose();
    }
}
