@using Chronocode.Services
@inject EmailViewerService EmailService

@if (IsLoading)
{
    <div class="text-center py-3">
        <div class="spinner-border spinner-border-sm me-2" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        Loading email...
    </div>
}
else if (EmailData != null)
{
    <div class="email-viewer border rounded p-3" style="background-color: #f8f9fa;">
        <!-- Email Headers -->
        <div class="email-headers mb-3 pb-3 border-bottom">
            <div class="row mb-2">
                <div class="col-12">
                    <h5 class="mb-2">@EmailData.Subject</h5>
                </div>
            </div>
            
            <div class="row mb-1">
                <div class="col-2 text-muted"><strong>From:</strong></div>
                <div class="col-10">@EmailData.From</div>
            </div>
            
            @if (!string.IsNullOrEmpty(EmailData.To))
            {
                <div class="row mb-1">
                    <div class="col-2 text-muted"><strong>To:</strong></div>
                    <div class="col-10">@EmailData.To</div>
                </div>
            }
            
            @if (!string.IsNullOrEmpty(EmailData.Cc))
            {
                <div class="row mb-1">
                    <div class="col-2 text-muted"><strong>Cc:</strong></div>
                    <div class="col-10">@EmailData.Cc</div>
                </div>
            }
            
            @if (!string.IsNullOrEmpty(EmailData.Bcc))
            {
                <div class="row mb-1">
                    <div class="col-2 text-muted"><strong>Bcc:</strong></div>
                    <div class="col-10">@EmailData.Bcc</div>
                </div>
            }
            
            <div class="row mb-1">
                <div class="col-2 text-muted"><strong>Date:</strong></div>
                <div class="col-10">@EmailData.SentDate.ToString("MMMM d, yyyy h:mm tt")</div>
            </div>
            
            @if (EmailData.HasAttachments)
            {
                <div class="row mb-1">
                    <div class="col-2 text-muted"><strong>Attachments:</strong></div>
                    <div class="col-10">
                        <span class="badge bg-info">@EmailData.Attachments.Count attachment(s)</span>
                    </div>
                </div>
            }
        </div>

        <!-- Email Body -->
        <div class="email-body">
            @if (!string.IsNullOrEmpty(EmailData.BodyHtml))
            {
                <div class="border rounded p-3 bg-white" style="max-height: 600px; overflow-y: auto;">
                    @((MarkupString)EmailData.BodyHtml)
                </div>
            }
            else if (!string.IsNullOrEmpty(EmailData.BodyText))
            {
                <div class="border rounded p-3 bg-white" style="max-height: 600px; overflow-y: auto;">
                    <pre style="margin: 0; white-space: pre-wrap; word-wrap: break-word; font-family: 'Courier New', monospace; font-size: 0.9em;">@EmailData.BodyText</pre>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    This email has no body content.
                </div>
            }
        </div>

        <!-- Attachments List -->
        @if (EmailData.HasAttachments)
        {
            <div class="email-attachments mt-3 pt-3 border-top">
                <h6 class="mb-2"><i class="fas fa-paperclip me-2"></i>Attachments</h6>
                <div class="list-group">
                    @foreach (var attachment in EmailData.Attachments)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <i class="fas fa-file me-2"></i>
                                <strong>@attachment.FileName</strong>
                                <small class="text-muted ms-2">(@FormatFileSize(attachment.Size))</small>
                                @if (attachment.IsInline)
                                {
                                    <span class="badge bg-secondary ms-2">Inline</span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="alert alert-info mt-2 mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    Attachments are embedded in the .msg file. To access them, download the original .msg file.
                </div>
            </div>
        }
    </div>
}
else if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger">
        <i class="fas fa-exclamation-triangle me-2"></i>
        @ErrorMessage
    </div>
}

@code {
    [Parameter]
    public int ArtifactId { get; set; }

    private EmailData? EmailData { get; set; }
    private bool IsLoading { get; set; } = true;
    private string? ErrorMessage { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await LoadEmailData();
    }

    private async Task LoadEmailData()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            EmailData = await EmailService.ParseEmailAsync(ArtifactId);
            
            if (EmailData == null)
            {
                ErrorMessage = "Failed to load email. The file may not be a valid .msg file.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading email: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}
