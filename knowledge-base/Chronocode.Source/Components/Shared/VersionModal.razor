@using Chronocode.Data.Models
@using Chronocode.Services
@inject VersionService VersionService
@inject IJSRuntime JSRuntime

<!-- Version Modal -->
<div class="modal fade" id="versionModal" tabindex="-1" aria-labelledby="versionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="versionModalLabel">
                    <i class="bi bi-info-circle me-2"></i>Chronocode Version Information
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @if (currentVersion != null)
                {
                    <!-- Current Version Section -->
                    <div class="card mb-4 border-primary">
                        <div class="card-header bg-primary text-white">
                            <h6 class="mb-0">
                                <i class="bi bi-star-fill me-2"></i>Current Version: @currentVersion.Version
                            </h6>
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-2">
                                <i class="bi bi-calendar me-1"></i>Released: @currentVersion.ReleaseDate.ToString("MMMM dd, yyyy")
                            </p>
                            <p class="mb-3">@currentVersion.Description</p>
                            
                            @if (currentVersion.NewFeatures.Any())
                            {
                                <div class="mb-3">
                                    <h6 class="text-success">
                                        <i class="bi bi-plus-circle me-1"></i>New Features
                                    </h6>
                                    <ul class="list-unstyled ms-3">
                                        @foreach (var feature in currentVersion.NewFeatures)
                                        {
                                            <li><i class="bi bi-check text-success me-2"></i>@feature</li>
                                        }
                                    </ul>
                                </div>
                            }

                            @if (currentVersion.Improvements.Any())
                            {
                                <div class="mb-3">
                                    <h6 class="text-info">
                                        <i class="bi bi-arrow-up-circle me-1"></i>Improvements
                                    </h6>
                                    <ul class="list-unstyled ms-3">
                                        @foreach (var improvement in currentVersion.Improvements)
                                        {
                                            <li><i class="bi bi-check text-info me-2"></i>@improvement</li>
                                        }
                                    </ul>
                                </div>
                            }

                            @if (currentVersion.BugFixes.Any())
                            {
                                <div class="mb-3">
                                    <h6 class="text-warning">
                                        <i class="bi bi-bug me-1"></i>Bug Fixes
                                    </h6>
                                    <ul class="list-unstyled ms-3">
                                        @foreach (var bugFix in currentVersion.BugFixes)
                                        {
                                            <li><i class="bi bi-check text-warning me-2"></i>@bugFix</li>
                                        }
                                    </ul>
                                </div>
                            }

                            @if (currentVersion.BreakingChanges.Any())
                            {
                                <div class="mb-3">
                                    <h6 class="text-danger">
                                        <i class="bi bi-exclamation-triangle me-1"></i>Breaking Changes
                                    </h6>
                                    <ul class="list-unstyled ms-3">
                                        @foreach (var breakingChange in currentVersion.BreakingChanges)
                                        {
                                            <li><i class="bi bi-exclamation-circle text-danger me-2"></i>@breakingChange</li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Version History Section -->
                <div class="card">
                    <div class="card-header">
                        <h6 class="mb-0">
                            <i class="bi bi-clock-history me-2"></i>Version History
                        </h6>
                    </div>
                    <div class="card-body">
                        @if (versionHistory.Any())
                        {
                            @foreach (var version in versionHistory)
                            {
                                <div class="mb-3 pb-3 @(version.IsCurrent ? "" : "border-bottom")">
                                    <div class="d-flex align-items-center mb-2">
                                        <span class="badge @GetVersionBadgeClass(version.Type) me-2">
                                            @version.Version
                                        </span>
                                        <span class="text-muted small">
                                            @version.ReleaseDate.ToString("MMM dd, yyyy")
                                        </span>
                                        @if (version.IsCurrent)
                                        {
                                            <span class="badge bg-primary ms-2">Current</span>
                                        }
                                    </div>

                                    @if (version.NewFeatures.Any() || version.Improvements.Any() || version.BugFixes.Any())
                                    {
                                        <div class="small">
                                            @if (version.NewFeatures.Any())
                                            {
                                                <span class="text-success me-2">
                                                    <i class="bi bi-plus-circle"></i> @version.NewFeatures.Count new feature(s)
                                                </span>
                                            }
                                            @if (version.Improvements.Any())
                                            {
                                                <span class="text-info me-2">
                                                    <i class="bi bi-arrow-up-circle"></i> @version.Improvements.Count improvement(s)
                                                </span>
                                            }
                                            @if (version.BugFixes.Any())
                                            {
                                                <span class="text-warning me-2">
                                                    <i class="bi bi-bug"></i> @version.BugFixes.Count bug fix(es)
                                                </span>
                                            }
                                            @if (version.BreakingChanges.Any())
                                            {
                                                <span class="text-danger">
                                                    <i class="bi bi-exclamation-triangle"></i> @version.BreakingChanges.Count breaking change(s)
                                                </span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted">No version history available.</p>
                        }
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="me-auto">
                    <small class="text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        Following <a href="https://semver.org/" target="_blank" class="text-decoration-none">Semantic Versioning</a> principles
                    </small>
                </div>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@code {
    private VersionInfo? currentVersion;
    private List<VersionInfo> versionHistory = new();

    protected override void OnInitialized()
    {
        currentVersion = VersionService.GetCurrentVersionInfo();
        versionHistory = VersionService.GetRecentVersions(10); // Show last 10 versions
    }

    private static string GetVersionBadgeClass(VersionType type)
    {
        return type switch
        {
            VersionType.Major => "bg-danger",
            VersionType.Minor => "bg-warning",
            VersionType.Patch => "bg-success",
            _ => "bg-secondary"
        };
    }
}
