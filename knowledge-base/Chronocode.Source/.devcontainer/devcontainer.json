{
  "name": "Blazor .NET 9 Dev Container",
  "image": "mcr.microsoft.com/devcontainers/dotnet:1-9.0", // Official devcontainers .NET 9 image with vscode user
  "postCreateCommand": "dotnet restore",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "forwardPorts": [5000, 5001],
  "remoteUser": "vscode"
}
